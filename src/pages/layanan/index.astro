---
import Layout from "@/layouts/Layout.astro";
import Header from "@/layouts/Header.astro";
import Footer from "@/layouts/Footer.astro";
import FocusIn from "@/components/FocusIn.astro";
import { project1 } from "@/data/portfolio";
import { getLocale, getMessages } from "@/lib/i18n";

const locale = getLocale(Astro);
const m = getMessages(locale);
const ogImage = new URL(project1.src, Astro.site).href;
---

<Layout
  title={m.meta.layananTitle}
  description={m.meta.layananDescription}
  ogImage={ogImage}
>
  <Header />

  <main class="pt-28">
    <section class="mx-auto container px-4 pb-12 md:px-6">
      <FocusIn delay={60}>
        <p class="mb-4 font-mono text-xs tracking-[0.2em] uppercase">
          {m.layanan.eyebrow}
        </p>
        <div
          class="flex flex-col gap-6 border-b border-border pb-10 md:flex-row md:items-end md:justify-between"
        >
          <h1
            class="max-w-2xl text-balance font-display text-4xl italic leading-[0.95] md:text-6xl"
          >
            {m.layanan.title}
          </h1>
          <p class="max-w-sm text-sm leading-relaxed">
            {m.layanan.subtitle}
          </p>
        </div>
      </FocusIn>
    </section>

    <section id="layanan" class="mx-auto container px-4 py-12 md:px-6">
      <FocusIn class="mb-16 flex items-end justify-between">
        <div>
          <p class="mb-4 font-mono text-xs tracking-[0.2em] uppercase">
            {m.layanan.servicesEyebrow}
          </p>
          <h2 class="font-display text-5xl italic">
            {m.layanan.servicesTitle}
          </h2>
        </div>
      </FocusIn>

      <ul class="grid grid-cols-1 gap-px bg-border sm:grid-cols-2">
        {
          m.layanan.services.map((s, i) => (
            <FocusIn
              as="li"
              delay={i * 80}
              data-cursor="focus"
              data-cursor-label="Detail"
              class="group bg-background p-10 transition-colors hover:bg-accent/5"
            >
              <p class="mb-6 font-mono text-xs tracking-[0.2em] text-accent uppercase">
                {s.n}
              </p>
              <h3 class="mb-3 font-display text-3xl italic">{s.t}</h3>
              <p class="text-sm leading-relaxed">{s.d}</p>
            </FocusIn>
          ))
        }
      </ul>
    </section>

    <section
      id="proses"
      class="border-y border-border bg-surface/40 px-4 py-20 md:px-6"
    >
      <div class="mx-auto container px-4 md:px-6">
        <FocusIn>
          <p class="mb-4 font-mono text-xs tracking-widest uppercase">
            {m.layanan.processEyebrow}
          </p>
          <h2
            class="mb-16 font-display text-5xl italic leading-tight md:max-w-2xl"
          >
            {m.layanan.processTitle}
          </h2>
        </FocusIn>
        <ol class="grid grid-cols-1 gap-12 md:grid-cols-4">
          {
            m.layanan.process.map((p, i) => (
              <FocusIn
                as="li"
                delay={i * 90}
                class="border-t border-foreground/20 pt-6"
              >
                <span class="mb-6 block font-mono text-xs tracking-widest text-accent uppercase">
                  {p.n}
                </span>
                <h3 class="mb-3 font-display text-2xl italic">{p.t}</h3>
                <p class="text-sm leading-relaxed">{p.d}</p>
              </FocusIn>
            ))
          }
        </ol>
      </div>
    </section>

    <section id="faq" class="mx-auto container px-4 py-20 md:px-6">
      <FocusIn>
        <p class="mb-4 font-mono text-xs tracking-widest uppercase">
          {m.layanan.faqEyebrow}
        </p>
        <h2 class="mb-16 font-display text-5xl italic">{m.layanan.faqTitle}</h2>
      </FocusIn>
      <ul class="divide-y divide-border border-y border-border">
        {
          m.layanan.faq.map((f, i) => (
            <FocusIn
              as="li"
              delay={i * 70}
              data-cursor="focus"
              data-cursor-label="Read"
              class="grid grid-cols-1 gap-4 py-8 md:grid-cols-12"
            >
              <h3 class="font-display text-xl italic md:col-span-5">{f.q}</h3>
              <p class="text-sm leading-relaxed md:col-span-7">{f.a}</p>
            </FocusIn>
          ))
        }
      </ul>
    </section>

    <section
      class="bg-surface/40 px-4 py-10 md:px-6"
      aria-label={m.layanan.ctaAria}
    >
      <div class="mx-auto container px-4 md:px-6">
        <FocusIn class="grid items-end gap-12 md:grid-cols-12">
          <div class="md:col-span-7">
            <p class="mb-4 font-mono text-xs tracking-[0.2em] uppercase">
              {m.common.collaboration}
            </p>
            <h2 class="font-display text-4xl italic leading-tight md:text-5xl">
              {m.layanan.ctaTitle}
            </h2>
          </div>
          <div class="flex flex-wrap gap-3 md:col-span-5 md:justify-end">
            <a
              href="/#kontak"
              data-cursor="focus"
              data-cursor-label="Email"
              class="rounded-full bg-foreground px-8 py-4 text-sm font-medium text-background transition-colors hover:bg-accent"
            >
              {m.common.startProject}
            </a>
          </div>
        </FocusIn>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
