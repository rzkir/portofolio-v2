---
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Header from "@/layouts/Header.astro";
import Footer from "@/layouts/Footer.astro";
import CodingStats from "@/components/CodingStats.astro";
import CvDialog from "@/components/CvDialog.astro";
import GuestNotes from "@/components/GuestNotes.astro";
import InfiniteMarquee from "@astroanimate/core/InfiniteMarquee";
import FocusIn from "@/components/FocusIn.astro";
import WorksScroll from "@/components/WorksScroll.astro";
import ArchivmentsLayout from "@/components/ArchivmentsLayout.astro";
import CareerLayout from "@/components/CareerLayout.astro";
import {
  certifications,
  faq,
  portrait,
  process,
  project1,
  services,
  stack,
  testimonials,
} from "@/data/portfolio";

const ogImage = new URL(project1.src, Astro.site).href;
---

<Layout
  title="R. Ramadhan — Freelance Fullstack Developer"
  description="Crafting human-centric code in a machine world. Portfolio Rizki Ramadhan, freelance fullstack developer dari Bogor, Indonesia."
  ogImage={ogImage}
>
  <Header />

  <main class="pt-28">
    <!-- HERO -->
    <section class="mx-auto container px-4 md:px-6">
      <div
        class="mb-8 inline-flex animate-focus items-center gap-2 rounded-full border border-accent/20 bg-accent/5 px-3 py-1"
      >
        <span class="size-1.5 pulse-soft rounded-full bg-accent"></span>
        <span
          class="font-mono text-[10px] uppercase tracking-[0.2em] text-accent"
          >Available for 2026 projects</span
        >
      </div>

      <h1
        class="mb-12 animate-focus text-balance font-display text-6xl italic leading-[0.9] [animation-delay:100ms] md:text-8xl"
      >
        Crafting human-centric code in a machine world.
      </h1>

      <div
        class="grid animate-focus grid-cols-1 items-end gap-12 [animation-delay:200ms] md:grid-cols-12"
      >
        <div class="md:col-span-5">
          <p
            class="mb-4 font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
          >
            Index / 00 — Pengantar
          </p>
          <p class="text-pretty text-lg leading-relaxed">
            Halo, saya Rizki Ramadhan — freelance fullstack developer dari
            Indonesia dengan lebih dari dua tahun pengalaman membangun website
            dan aplikasi dari konsep hingga deployment.
          </p>
        </div>
        <div class="flex flex-wrap justify-end gap-3 md:col-span-7">
          <CvDialog>
            <button
              slot="trigger"
              type="button"
              data-dialog-open="cv-dialog"
              data-cursor="focus"
              data-cursor-label="View"
              class="rounded-full border border-border px-8 py-4 text-sm font-medium transition-colors hover:border-accent hover:text-accent"
            >
              Lihat CV →
            </button>
          </CvDialog>
          <a
            href="#kontak"
            data-cursor="focus"
            data-cursor-label="Email"
            class="rounded-full bg-foreground px-8 py-4 text-sm font-medium text-background transition-colors hover:bg-accent"
          >
            Mulai proyek →
          </a>
        </div>
      </div>
    </section>

    <!-- MARQUEE -->
    <FocusIn class="mt-32 overflow-hidden border-y border-border py-6">
      <div class="flex whitespace-nowrap marquee">
        {
          [0, 1].map(() => (
            <div class="flex shrink-0 items-center gap-12 px-6">
              {stack.map((s) => (
                <>
                  <span class="font-display text-3xl italic opacity-40">
                    {s}
                  </span>
                  <span class="size-1.5 rounded-full bg-border" />
                </>
              ))}
            </div>
          ))
        }
      </div>
    </FocusIn>

    <!-- ABOUT -->
    <section
      class="mx-auto container grid items-start gap-16 px-4 py-20 md:grid-cols-12 md:px-6"
    >
      <FocusIn class="md:col-span-5" delay={0}>
        <figure
          data-cursor="grab"
          class="overflow-hidden rounded-2xl bg-surface"
        >
          <Image
            src={portrait}
            alt="R. Ramadhan — Studio, 2026"
            class="aspect-4/5 w-full object-cover grayscale"
          />
        </figure>
        <figcaption
          class="mt-3 font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
        >
          Fig. 01 — Studio, 2026 · BOGOR · ID
        </figcaption>
      </FocusIn>

      <FocusIn class="md:col-span-7" delay={120}>
        <p
          class="mb-8 font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
        >
          Tentang / 01
        </p>
        <h2 class="mb-8 font-display text-4xl italic leading-tight">
          Memadukan presisi teknik dengan narasi visual — tiap baris kode adalah
          keputusan desain.
        </h2>
        <p
          class="mb-12 text-pretty text-base leading-relaxed text-muted-foreground"
        >
          Saya mengerjakan keseluruhan siklus produk: dari riset singkat, desain
          antarmuka, hingga deployment di production. Background saya kuat di
          frontend modern (React, Next.js, TanStack) dengan backend pragmatis
          menggunakan Node.js, Postgres, dan Supabase.
        </p>

        <dl
          class="grid grid-cols-2 gap-y-10 gap-x-8 border-t border-border pt-12"
        >
          <div>
            <dt
              class="mb-1 font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
            >
              Pengalaman
            </dt>
            <dd class="font-display text-3xl italic">2+ thn</dd>
          </div>
          <div>
            <dt
              class="mb-1 font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
            >
              Proyek selesai
            </dt>
            <dd class="font-display text-3xl italic">20+</dd>
          </div>
          <div>
            <dt
              class="mb-1 font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
            >
              Sertifikasi
            </dt>
            <dd class="font-display text-3xl italic">
              {certifications.length}
            </dd>
          </div>
          <div>
            <dt
              class="mb-1 font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
            >
              Status
            </dt>
            <dd class="font-display text-3xl italic text-accent">Open</dd>
          </div>
        </dl>
      </FocusIn>
    </section>

    <WorksScroll />

    <!-- LAYANAN -->
    <section id="layanan" class="mx-auto container px-4 py-20 md:px-6">
      <FocusIn class="mb-16 flex items-end justify-between">
        <div>
          <p
            class="mb-4 font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase"
          >
            Layanan / 03
          </p>
          <h2 class="font-display text-5xl italic">
            Apa yang bisa saya kerjakan
          </h2>
        </div>
      </FocusIn>

      <ul class="grid grid-cols-1 gap-px bg-border sm:grid-cols-2">
        {
          services.map((s, i) => (
            <FocusIn
              as="li"
              delay={i * 80}
              data-cursor="focus"
              data-cursor-label="Detail"
              class="group bg-background p-10 transition-colors hover:bg-accent/5"
            >
              <p class="mb-6 font-mono text-[10px] tracking-[0.2em] text-accent uppercase">
                {s.n}
              </p>
              <h3 class="mb-3 font-display text-3xl italic">{s.t}</h3>
              <p class="text-sm leading-relaxed text-muted-foreground">{s.d}</p>
            </FocusIn>
          ))
        }
      </ul>
    </section>

    <!-- PROSES -->
    <section
      id="proses"
      class="border-y border-border bg-surface/40 px-4 py-20 md:px-6"
    >
      <div class="mx-auto container px-4 md:px-6">
        <FocusIn>
          <p
            class="mb-4 font-mono text-xs tracking-widest text-muted-foreground uppercase"
          >
            Proses / 04
          </p>
          <h2
            class="mb-16 font-display text-5xl italic leading-tight md:max-w-2xl"
          >
            Empat langkah, tanpa drama.
          </h2>
        </FocusIn>
        <ol class="grid grid-cols-1 gap-12 md:grid-cols-4">
          {
            process.map((p, i) => (
              <FocusIn
                as="li"
                delay={i * 90}
                class="border-t border-foreground/20 pt-6"
              >
                <span class="mb-6 block font-mono text-xs tracking-widest text-accent uppercase">
                  {p.n}
                </span>
                <h3 class="mb-3 font-display text-2xl italic">{p.t}</h3>
                <p class="text-sm leading-relaxed text-muted-foreground">
                  {p.d}
                </p>
              </FocusIn>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- TESTIMONI -->
    <section
      class="relative overflow-hidden border-y border-border bg-surface/40 py-20"
      aria-label="Testimoni klien"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_0%,color-mix(in_oklch,var(--accent)_8%,transparent),transparent)]"
        aria-hidden="true"
      >
      </div>

      <div class="relative mx-auto container px-4 md:px-6">
        <FocusIn>
          <p
            class="mb-4 font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase"
          >
            Suara Klien / 05
          </p>
          <h2 class="mb-16 max-w-3xl font-display text-5xl italic">
            Apa kata mereka yang pernah berkolaborasi.
          </h2>
        </FocusIn>
      </div>

      <FocusIn class="relative mt-2">
        <InfiniteMarquee
          direction="left"
          speed="52s"
          pauseOnHover={true}
          gap="1.5rem"
          fade={true}
        >
          {
            testimonials.map((t, i) => (
              <figure
                data-cursor="focus"
                data-cursor-label="Read"
                class:list={[
                  "flex w-[min(88vw,22rem)] shrink-0 flex-col justify-between gap-8 border p-8 shadow-[0_1px_0_0_color-mix(in_oklch,var(--foreground)_4%,transparent)] transition-colors md:w-96",
                  i % 2 === 0
                    ? "border-border/80 bg-background"
                    : "border-accent/15 bg-accent/4",
                ]}
              >
                <blockquote class="font-display text-2xl leading-snug italic whitespace-normal">
                  "{t.quote}"
                </blockquote>
                <figcaption class="border-t border-border/60 pt-6">
                  <p class="text-sm font-medium">{t.author}</p>
                  <p class="text-xs text-muted-foreground">{t.role}</p>
                </figcaption>
              </figure>
            ))
          }
        </InfiniteMarquee>
      </FocusIn>
    </section>

    <CareerLayout />

    <ArchivmentsLayout />

    <!-- FAQ -->
    <section class="mx-auto container px-4 py-20 md:px-6">
      <FocusIn>
        <p
          class="mb-4 font-mono text-xs tracking-widest text-muted-foreground uppercase"
        >
          FAQ / 08
        </p>
        <h2 class="mb-16 font-display text-5xl italic">Pertanyaan umum.</h2>
      </FocusIn>
      <ul class="divide-y divide-border border-y border-border">
        {
          faq.map((f, i) => (
            <FocusIn
              as="li"
              delay={i * 70}
              data-cursor="focus"
              data-cursor-label="Read"
              class="grid grid-cols-1 gap-4 py-8 md:grid-cols-12"
            >
              <h3 class="font-display text-xl italic md:col-span-5">{f.q}</h3>
              <p class="text-sm leading-relaxed text-muted-foreground md:col-span-7">
                {f.a}
              </p>
            </FocusIn>
          ))
        }
      </ul>
    </section>

    <CodingStats />
    <GuestNotes />
  </main>
  <Footer />
</Layout>
