---
import Layout from "@/layouts/Layout.astro";
import Header from "@/layouts/Header.astro";
import Footer from "@/layouts/Footer.astro";
import ArrowLeft from "@/components/svg/arrow-left.astro";
import ArrowUpRight from "@/components/svg/arrow-up-right.astro";
import Typography from "@/components/ui/typography.astro";
import { cn } from "@/lib/utiles";
import {
  formatWorkDate,
  getWorkBySlug,
  getWorkYear,
} from "@/service/works.service";
import { getLocale, getMessages } from "@/lib/i18n";

const locale = getLocale(Astro);
const m = getMessages(locale);

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/works");
}

let work: any;

try {
  work = await getWorkBySlug(slug);
} catch {
  return Astro.redirect("/works");
}

const category = work.categoryDetail?.name ?? work.category;
---

<Layout
  title={`${work.title} — Rizki Ramadhan`}
  description={work.description}
  ogImage={work.thumbnail}
  ogType="article"
  breadcrumbCurrent={work.title}
>
  <Header />

  <main class="min-h-screen bg-background pt-24 text-foreground">
    <section class="border-b border-border">
      <div
        class="mx-auto container w-full grid grid-cols-2 gap-x-10 gap-y-8 px-4 py-5 md:grid-cols-4 md:px-6"
      >
        <div>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
          >
            {m.workDetail.category}
          </p>
          <p class="mt-2 text-sm">{category}</p>
        </div>
        <div>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
          >
            {m.workDetail.published}
          </p>
          <p class="mt-2 text-sm">{formatWorkDate(work.createdAt)}</p>
        </div>
        <div>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
          >
            {m.workDetail.updated}
          </p>
          <p class="mt-2 text-sm">{formatWorkDate(work.updatedAt)}</p>
        </div>
        <div>
          <p
            class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
          >
            {m.workDetail.live}
          </p>
          <p class="mt-2 text-sm">
            <a
              href={work.previewLink}
              target="_blank"
              rel="noopener noreferrer"
              data-cursor="focus"
              data-cursor-label="Open"
              class="inline-flex items-center gap-1 text-foreground underline decoration-border underline-offset-4 transition-colors hover:decoration-accent"
            >
              {m.workDetail.visit}
              <ArrowUpRight size={14} />
            </a>
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto container w-full px-4 py-10 md:px-6">
      <h1
        class="max-w-4xl font-display text-4xl leading-[1.05] tracking-tight md:text-6xl lg:text-7xl"
      >
        {work.title}
      </h1>
      <p
        class="mt-8 max-w-2xl text-base leading-relaxed text-muted-foreground md:text-lg"
      >
        {work.description}
      </p>
    </section>

    <section class="mx-auto container w-full px-4 md:px-6">
      <figure
        class="overflow-hidden rounded-md border border-border bg-surface"
      >
        <img
          src={work.thumbnail}
          alt={work.title}
          loading="eager"
          decoding="async"
          class="aspect-video w-full object-cover"
        />
      </figure>
    </section>

    <section class="mx-auto container w-full px-4 py-10 md:px-6">
      <div class="grid grid-cols-1 gap-16 md:grid-cols-12">
        <aside class="md:sticky md:top-28 md:col-span-4 md:self-start">
          <div class="space-y-10">
            <div>
              <h2
                class="font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground"
              >
                {m.workDetail.stack}
              </h2>
              <ul class="mt-5 space-y-3">
                {
                  work.frameworks.map((framework: any) => (
                    <li class="flex items-center gap-3 border-b border-border pb-3 last:border-b-0">
                      <span class="flex size-7 items-center justify-center overflow-hidden rounded-sm border border-border bg-surface">
                        <img
                          src={framework.imageUrl}
                          alt={framework.title}
                          width={28}
                          height={28}
                          loading="lazy"
                          decoding="async"
                          class="size-full object-cover"
                        />
                      </span>
                      <span class="text-sm">{framework.title}</span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <div>
              <h2
                class="font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground"
              >
                {m.workDetail.project}
              </h2>
              <dl class="mt-5 space-y-3 text-sm">
                <div
                  class="flex justify-between gap-4 border-b border-border pb-3"
                >
                  <dt class="text-muted-foreground">{m.workDetail.type}</dt>
                  <dd>{category}</dd>
                </div>
                <div
                  class="flex justify-between gap-4 border-b border-border pb-3"
                >
                  <dt class="text-muted-foreground">{m.workDetail.year}</dt>
                  <dd>{getWorkYear(work.createdAt)}</dd>
                </div>
                <div class="flex justify-between gap-4">
                  <dt class="text-muted-foreground">{m.workDetail.status}</dt>
                  <dd class="inline-flex items-center gap-2">
                    <span class="size-1.5 rounded-full bg-accent"></span>
                    {m.workDetail.statusLive}
                  </dd>
                </div>
              </dl>
            </div>

            <a
              href={work.previewLink}
              target="_blank"
              rel="noopener noreferrer"
              data-cursor="focus"
              data-cursor-label="Open"
              class="group inline-flex w-full items-center justify-between gap-3 border border-foreground bg-foreground px-5 py-3 text-sm text-background transition-colors hover:border-accent hover:bg-accent"
            >
              <span class="font-mono text-[12px] uppercase tracking-[0.18em]">
                {m.workDetail.viewProject}
              </span>
              <ArrowUpRight
                size={16}
                class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
              />
            </a>
          </div>
        </aside>

        <Typography content={work.content} class="md:col-span-8" />
      </div>
    </section>

    {
      work.imageUrl.length > 0 && (
        <section class="border-t border-border">
          <div class="mx-auto container w-full px-4 py-10 md:px-6">
            <div class="mb-12 flex items-end justify-between">
              <h2 class="font-display text-3xl md:text-5xl">{m.workDetail.gallery}</h2>
              <span class="font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">
                {m.workDetail.frames.replace(
                  "{count}",
                  String(work.imageUrl.length),
                )}
              </span>
            </div>
            <div class="columns-1 gap-6 md:columns-2">
              {work.imageUrl.map((src: any, i: number) => (
                <figure class="group mb-6 break-inside-avoid overflow-hidden rounded-md border border-border bg-surface">
                  <div class="overflow-hidden">
                    <img
                      src={src}
                      alt={`${work.title} — frame ${i + 1}`}
                      loading="lazy"
                      decoding="async"
                      class={cn(
                        "w-full object-cover transition-transform duration-700 ease-cinematic group-hover:scale-[1.03]",
                        i % 2 === 0 ? "aspect-4/3" : "aspect-video",
                      )}
                    />
                  </div>
                  <figcaption class="flex items-center justify-between border-t border-border px-4 py-3">
                    <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground">
                      {m.workDetail.fig.replace(
                        "{no}",
                        String(i + 1).padStart(2, "0"),
                      )}
                    </span>
                    <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-muted-foreground/60">
                      {String(i + 1).padStart(2, "0")} /{" "}
                      {String(work.imageUrl.length).padStart(2, "0")}
                    </span>
                  </figcaption>
                </figure>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <section class="border-t border-border">
      <div
        class="mx-auto container w-full flex flex-col items-start justify-between gap-6 px-4 py-10 md:flex-row md:items-end md:px-6"
      >
        <div>
          <p
            class="font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground"
          >
            {m.workDetail.nextEyebrow}
          </p>
          <h2 class="mt-3 font-display text-3xl md:text-4xl">
            {m.workDetail.nextTitle}
          </h2>
        </div>
        <a
          href="/#kontak"
          data-cursor="focus"
          data-cursor-label="Email"
          class="inline-flex items-center gap-2 border-b border-foreground pb-1 font-mono text-xs uppercase tracking-[0.2em] transition-colors hover:border-accent hover:text-accent"
        >
          {m.common.startProject.replace(" →", "")}
          <ArrowLeft size={14} class="rotate-180" />
        </a>
      </div>
    </section>
  </main>

  <a
    id="work-back-fab"
    href="/works"
    data-visible="false"
    data-cursor="focus"
    data-cursor-label="Back"
    aria-hidden="true"
    class={cn(
      "fixed bottom-6 left-1/2 z-40 inline-flex -translate-x-1/2 items-center gap-2 rounded-full border border-border bg-background/92 px-5 py-3 font-mono text-xs uppercase tracking-[0.18em] text-foreground shadow-[0_10px_40px_color-mix(in_oklch,var(--foreground)_10%,transparent)] backdrop-blur-md max-md:bottom-[calc(5.75rem+env(safe-area-inset-bottom,0px))]",
      "translate-y-10 opacity-0 pointer-events-none transition-[transform,opacity] duration-500 ease-cinematic",
      "hover:border-accent hover:text-accent",
      "data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100 data-[visible=true]:pointer-events-auto",
    )}
  >
    <ArrowLeft size={14} />
    {m.workDetail.backFab}
  </a>

  <Footer />
</Layout>

<script>
  import { bindBackTab } from "@/lib/back-tab";

  bindBackTab("work-back-fab");
  document.addEventListener("astro:page-load", () => bindBackTab("work-back-fab"));
</script>
