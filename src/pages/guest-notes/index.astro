---
import Layout from "@/layouts/Layout.astro";
import Header from "@/layouts/Header.astro";
import Footer from "@/layouts/Footer.astro";
import Input from "@/components/ui/input.astro";
import Select from "@/components/ui/select.astro";
import Textarea from "@/components/ui/textarea.astro";
import {
  GUEST_NOTE_PROVIDERS,
  getProviderLabel,
} from "@/lib/guest-note-providers";
import {
  getGuestNotes,
  formatGuestNoteDateFull,
} from "@/service/noted.service";

const notes = await getGuestNotes();
const noteCount = String(notes.length).padStart(2, "0");
const archiveCount = String(notes.length).padStart(3, "0");

const fieldClass =
  "font-display text-xl text-foreground placeholder:text-muted-foreground/50";
---

<Layout
  title="Buku Tamu — Tinggalkan catatan"
  description="Ruang tenang untuk meninggalkan catatan singkat."
>
  <Header />

  <main class="min-h-screen bg-background pt-28 text-foreground">
    <section class="mx-auto container px-4 md:px-6">
      <div
        class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between"
      >
        <div>
          <p
            class="font-mono text-[11px] tracking-[0.24em] text-muted-foreground uppercase"
          >
            Buku Tamu / <span id="guest-notes-hero-index">{noteCount}</span>
          </p>
          <h1
            class="mt-6 font-display text-5xl leading-[1.05] tracking-tight md:text-7xl"
          >
            Tinggalkan
            <br />
            catatan.
          </h1>
        </div>
        <div
          id="guest-notes-count"
          class="font-mono text-[11px] tracking-[0.18em] text-muted-foreground uppercase"
        >
          {notes.length} catatan
        </div>
      </div>
    </section>

    <section class="border-t border-border">
      <div
        class="mx-auto grid container grid-cols-1 gap-12 px-4 py-16 md:grid-cols-12 md:px-6"
      >
        <div class="md:col-span-4">
          <p
            class="font-mono text-[11px] tracking-[0.24em] text-muted-foreground uppercase"
          >
            // LEAVE_A_NOTE
          </p>
          <p
            class="mt-4 max-w-sm font-display text-2xl leading-snug text-foreground/80 italic"
          >
            Sapaan, kritik, atau sekedar say hi — semua diterima.
          </p>
        </div>

        <form
          id="guest-notes-form"
          class="space-y-8 md:col-span-8"
        >
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            <Input
              id="guest-name"
              name="name"
              label="Nama"
              maxlength={60}
              required
              placeholder="Siapa kamu?"
              inputClass={fieldClass}
            />
            <Select
              id="guest-provider"
              name="provider"
              label="Dari"
              options={[...GUEST_NOTE_PROVIDERS]}
              required
              selectClass={`cursor-pointer ${fieldClass}`}
            />
          </div>

          <Textarea
            id="guest-message"
            name="message"
            label="Pesan"
            maxlength={280}
            required
            rows={4}
            placeholder="Tulis sesuatu yang ringan…"
            textareaClass={`resize-none leading-snug ${fieldClass}`}
          >
            <span
              slot="label-extra"
              id="guest-message-count"
              class="font-mono text-[11px] text-muted-foreground"
            >
              0/280
            </span>
          </Textarea>

          <p
            id="guest-notes-error"
            class="hidden font-mono text-xs text-destructive"
          >
          </p>

          <div class="flex justify-end">
            <button
              type="submit"
              class="group inline-flex items-center gap-3 font-mono text-xs tracking-[0.24em] text-foreground uppercase transition-colors hover:text-accent disabled:opacity-50"
            >
              Kirim catatan
              <span class="transition-transform group-hover:translate-x-1"
                >→</span
              >
            </button>
          </div>
        </form>
      </div>
    </section>

    <section class="border-t border-border bg-surface/40">
      <div class="mx-auto container px-4 py-20 md:px-6">
        <div class="mb-12 flex items-baseline justify-between">
          <h2 class="font-display text-3xl tracking-tight md:text-4xl">
            Arsip catatan
          </h2>
          <span
            id="guest-notes-archive-count"
            class="font-mono text-[11px] tracking-[0.24em] text-muted-foreground uppercase"
          >
            N° {archiveCount}
          </span>
        </div>

        <p
          id="guest-notes-empty"
          class:list={[
            "py-16 text-center font-display text-2xl text-muted-foreground italic",
            notes.length > 0 && "hidden",
          ]}
        >
          Belum ada catatan — jadilah yang pertama.
        </p>

        <ol
          id="guest-notes-list"
          class:list={[
            "divide-y divide-border",
            notes.length === 0 && "hidden",
          ]}
        >
          {
            notes.map((note, index) => (
              <li class="grid grid-cols-12 gap-6 py-10 transition-colors hover:bg-background/60">
                <div class="col-span-12 md:col-span-1">
                  <span class="font-mono text-[11px] tracking-[0.24em] text-muted-foreground uppercase">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                </div>

                <blockquote class="col-span-12 md:col-span-8">
                  <p class="font-display text-2xl leading-snug text-foreground md:text-[1.75rem]">
                    <span class="mr-1 text-accent">“</span>
                    {note.message}
                    <span class="ml-1 text-accent">”</span>
                  </p>
                  <footer class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[11px] tracking-[0.18em] text-muted-foreground uppercase">
                    <span class="text-foreground/80">— {note.name}</span>
                    <span aria-hidden="true">·</span>
                    <span>{getProviderLabel(note.provider)}</span>
                  </footer>
                </blockquote>

                <div class="col-span-12 md:col-span-3 md:text-right">
                  <time class="font-mono text-[11px] tracking-[0.18em] text-muted-foreground uppercase">
                    {formatGuestNoteDateFull(note.createdAt)}
                  </time>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>
  </main>

  <Footer />

  <script
    id="guest-notes-bootstrap"
    type="application/json"
    set:html={JSON.stringify(notes)}
  />

  <script>
    import { bootGuestNotes } from "@/lib/guest-notes";

    bootGuestNotes();
    document.addEventListener("astro:page-load", bootGuestNotes);
  </script>
</Layout>
