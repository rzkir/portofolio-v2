---
import LangSwitcher from "@/components/LangSwitcher.astro";
import { cn } from "@/lib/utiles";
import { getLocale, getMessages } from "@/lib/i18n";

const locale = getLocale(Astro);
const m = getMessages(locale);

const navItems = [
  { index: "00", href: "/", label: m.nav.home, shortLabel: m.nav.shortHome },
  { index: "01", href: "/works", label: m.nav.works, shortLabel: m.nav.shortWorks },
  { index: "02", href: "/blog", label: m.nav.blog, shortLabel: m.nav.shortBlog },
  {
    index: "03",
    href: "/layanan",
    label: m.nav.services,
    shortLabel: m.nav.shortServices,
  },
  {
    index: "04",
    href: "/achievements",
    label: m.nav.achievements,
    shortLabel: m.nav.shortAchievements,
  },
  {
    index: "05",
    href: "/guest-notes",
    label: m.nav.guestNotes,
    shortLabel: m.nav.shortGuestNotes,
  },
];

const currentPath = Astro.url.pathname;

function isNavActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
}

const navLinkActive =
  "text-accent group-[.is-inverse]/site-header:text-background";

const desktopNavPillClass = cn(
  "relative m-0 flex list-none items-center gap-0.5 rounded-full border border-border bg-surface/55 p-0.5",
  "group-[.is-inverse]/site-header:border-background/18 group-[.is-inverse]/site-header:bg-background/8",
);

const mobileNavPillClass = cn(
  "relative m-0 flex list-none items-center gap-0.5 rounded-full border border-border bg-background/92 p-0.5 shadow-[0_10px_40px_color-mix(in_oklch,var(--foreground)_10%,transparent)] backdrop-blur-md",
);

const shellClass = cn(
  "pointer-events-auto transition-[background-color,box-shadow,backdrop-filter] duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]",
  "group-[.is-scrolled]/site-header:bg-background/88 group-[.is-scrolled]/site-header:backdrop-blur-md",
  "group-[.is-scrolled]/site-header:shadow-[0_1px_0_color-mix(in_oklch,var(--foreground)_4%,transparent)]",
  "group-[.is-inverse]/site-header:bg-transparent group-[.is-inverse]/site-header:shadow-none group-[.is-inverse]/site-header:backdrop-blur-none",
  "group-[.is-inverse.is-scrolled]/site-header:bg-accent/92 group-[.is-inverse.is-scrolled]/site-header:backdrop-blur-md",
);

const inverseText = "group-[.is-inverse]/site-header:text-background";
const inverseMuted = "group-[.is-inverse]/site-header:text-background/58";
---

<header
  id="site-header"
  class="group/site-header pointer-events-none fixed inset-x-0 top-0 z-50"
>
  <div class={shellClass}>
    <div class="mx-auto container px-4 md:px-6">
      <div
        class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-4 gap-y-4 py-4 lg:grid-cols-[minmax(0,1.1fr)_auto_minmax(0,auto)_auto] lg:gap-x-6 lg:py-5"
      >
        <a
          href="/"
          data-cursor="focus"
          data-cursor-label="Home"
          class={cn(
            "site-header__brand group/brand animate-focus flex min-w-0 flex-col gap-0.5 no-underline",
            inverseText,
          )}
        >
          <span
            class={cn(
              "font-display text-[clamp(1.35rem,2vw,1.75rem)] leading-none italic transition-colors duration-350 ease-cinematic",
              "group-hover/brand:text-accent",
              "group-[.is-inverse]/site-header:group-hover/brand:text-foreground",
            )}
          >
            R. Ramadhan
          </span>
          <span
            class={cn(
              "font-mono text-[0.5625rem] tracking-[0.22em] uppercase text-muted-foreground transition-colors duration-350 ease-cinematic",
              "group-hover/brand:text-accent/70",
              inverseMuted,
              "group-[.is-inverse]/site-header:group-hover/brand:text-foreground/65",
            )}
          >
            {m.brand.tagline}
          </span>
        </a>

        <nav
          class="site-header__nav animate-focus hidden [animation-delay:120ms] lg:block lg:justify-self-center"
          aria-label={m.nav.main}
        >
          <ul data-header-nav class={desktopNavPillClass}>
            <span
              data-header-nav-indicator
              aria-hidden="true"
              class={cn(
                "site-header__nav-indicator pointer-events-none absolute top-0 left-0 z-0 rounded-full",
                "bg-foreground/6 group-[.is-inverse]/site-header:bg-background/12",
              )}></span>
            {
              navItems.map((item) => (
                <li class="shrink-0">
                  <a
                    href={item.href}
                    data-header-nav-link
                    data-cursor="focus"
                    data-cursor-label="Go"
                    aria-current={isNavActive(item.href) ? "page" : undefined}
                    class={cn(
                      "relative z-10 inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-[0.625rem] font-medium tracking-[0.16em] uppercase no-underline",
                      "transition-colors duration-350 ease-cinematic",
                      "hover:text-accent focus-visible:text-accent",
                      inverseText,
                      "group-[.is-inverse]/site-header:hover:text-background",
                      "group-[.is-inverse]/site-header:focus-visible:text-background",
                      isNavActive(item.href) && navLinkActive,
                    )}
                  >
                    <span
                      class={cn(
                        "font-mono text-[0.5625rem] tracking-[0.14em] text-accent/75",
                        "group-[.is-inverse]/site-header:text-background/72",
                      )}
                    >
                      {item.index}
                    </span>
                    <span>{item.label}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <div
          class="site-header__actions animate-focus flex [animation-delay:200ms] items-center justify-end"
        >
          <LangSwitcher />
        </div>
      </div>
    </div>
  </div>

  <nav
    class="site-header__mobile-dock pointer-events-auto fixed inset-x-0 bottom-[max(0.85rem,env(safe-area-inset-bottom))] z-50 px-4 lg:hidden"
    aria-label={m.nav.mobile}
  >
    <ul
      data-header-nav-mobile
      class={cn(mobileNavPillClass, "site-header__mobile-pill flex w-full")}
    >
      <span
        data-header-nav-indicator
        aria-hidden="true"
        class="site-header__nav-indicator pointer-events-none absolute top-0 left-0 z-0 rounded-full bg-foreground/6"
      ></span>
      {
        navItems.map((item) => (
          <li class="min-w-0 flex-1">
            <a
              href={item.href}
              data-header-nav-link
              data-cursor="focus"
              data-cursor-label="Go"
              aria-current={isNavActive(item.href) ? "page" : undefined}
              aria-label={item.label}
              class={cn(
                "relative z-10 flex w-full flex-col items-center gap-0.5 rounded-full px-1 py-2 no-underline",
                "transition-colors duration-350 ease-cinematic",
                "text-foreground/72 hover:text-accent focus-visible:text-accent",
                isNavActive(item.href) && "text-accent",
              )}
            >
              <span class="font-mono text-[0.5rem] tracking-[0.14em] text-accent/80">
                {item.index}
              </span>
              <span class="w-full truncate text-center text-[0.5625rem] font-medium tracking-widest uppercase">
                {item.shortLabel}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  import { bindSiteHeader } from "@/service/header.service";

  function initSiteHeader() {
    bindSiteHeader();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSiteHeader, {
      once: true,
    });
  } else {
    initSiteHeader();
  }

  document.addEventListener("astro:page-load", initSiteHeader);
</script>

<style is:global>
  @keyframes site-header-indicator-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes site-header-dock-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .site-header__nav-indicator {
    opacity: 0;
    animation: site-header-indicator-in 0.55s var(--ease-cinematic) 680ms both;
    transition:
      transform 0.45s var(--ease-cinematic),
      width 0.45s var(--ease-cinematic),
      height 0.45s var(--ease-cinematic);
    will-change: transform, width, height;
  }

  .site-header__nav-indicator.is-visible {
    opacity: 1;
  }

  html.splash-pending .site-header__nav-indicator {
    animation-play-state: paused;
  }

  .site-header__mobile-dock {
    opacity: 0;
    transform: translateY(16px);
    animation: site-header-dock-in 0.72s var(--ease-cinematic) 260ms both;
  }

  html.splash-pending .site-header__mobile-dock {
    animation-play-state: paused;
  }

  .site-header__mobile-pill {
    width: 100%;
  }

  @media (max-width: 1023px) {
    body {
      padding-bottom: calc(5.25rem + env(safe-area-inset-bottom, 0px));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__nav-indicator,
    .site-header__mobile-dock {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
