---
import FocusIn from "@/components/FocusIn.astro";
import { contact, socialLinks } from "@/data/portfolio";
---

<footer
  id="kontak"
  data-header-theme="inverse"
  class="rounded-t-[3rem] bg-accent px-4 py-20 text-background md:px-6"
>
  <div class="mx-auto container px-4 md:px-6">
    <div class="grid gap-20 md:grid-cols-12">
      <FocusIn class="md:col-span-7">
        <p
          class="mb-12 font-mono text-xs tracking-widest text-background/50 uppercase"
        >
          Kontak / 09
        </p>
        <h2
          class="mb-12 font-display text-5xl leading-none text-background italic md:text-7xl"
        >
          Mari berkolaborasi di tahun 2026.
        </h2>
        <div class="flex flex-col gap-4">
          <a
            href={`mailto:${contact.email}`}
            data-cursor="focus"
            data-cursor-label="Send"
            class="inline-flex w-fit items-center gap-3 border-b border-background/40 pb-2 text-lg font-medium text-background transition-colors hover:border-background"
          >
            {contact.email} →
          </a>
          <a
            href={contact.website}
            target="_blank"
            rel="noopener noreferrer"
            data-cursor="focus"
            data-cursor-label="Open"
            class="inline-flex w-fit items-center gap-3 font-mono text-xs tracking-widest text-background/70 uppercase transition-colors hover:text-background"
          >
            {contact.websiteLabel} →
          </a>
        </div>
      </FocusIn>

      <FocusIn
        class="flex flex-col justify-end gap-12 md:col-span-5"
        delay={120}
      >
        <div class="grid grid-cols-2 gap-8">
          <div>
            <p
              class="mb-4 font-mono text-xs tracking-widest text-background/50 uppercase"
            >
              Sosial
            </p>
            <ul class="space-y-2 text-sm text-background/90">
              {
                socialLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      data-cursor="focus"
                      data-cursor-label="Open"
                      class="transition-opacity hover:text-background"
                    >
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
          <div>
            <p
              class="mb-4 font-mono text-xs tracking-widest text-background/50 uppercase"
            >
              Lokasi
            </p>
            <p class="text-sm text-background/90">{contact.location}</p>
            <p class="text-xs text-background/60">{contact.timezone}</p>
            <p
              class="mt-4 font-mono text-xs tracking-widest text-background/50 uppercase"
            >
              Status
            </p>
            <p class="text-sm text-background/90">{contact.status}</p>
          </div>
        </div>
      </FocusIn>
    </div>

    <div
      class="mt-32 flex flex-col items-center justify-between gap-4 border-t border-background/10 pt-8 font-mono text-xs tracking-widest text-background/50 uppercase md:flex-row"
    >
      <p>© 2026 Rizki Ramadhan — All rights reserved</p>
      <p>Set in Cormorant Garamond & Inter · Crafted with intention</p>
    </div>
  </div>
</footer>
