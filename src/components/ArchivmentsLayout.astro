---
import FocusIn from "@/components/FocusIn.astro";
import CredentialsGrid from "@/components/CredentialsGrid.astro";
import { fetchAchievementsPage } from "@/utils/FetchArchivments";
import { mapAchievementItems } from "@/service/archivments.service";
import { getLocale, getMessages } from "@/lib/i18n";

const locale = getLocale(Astro);
const m = getMessages(locale);

const meta = await fetchAchievementsPage({ page: 1 });
const credentials = mapAchievementItems(meta.data);

const hasMore = meta.nextPage;
---

<section
  id="kredensial"
  class="border-t border-border bg-surface/40 px-4 py-20 md:px-6"
>
  <div class="mx-auto container px-4 md:px-6">
    <FocusIn class="mb-12 flex items-end justify-between gap-4">
      <p class="font-mono text-xs tracking-widest uppercase">
        {m.achievementsSection.eyebrow}
      </p>
      <div class="flex flex-col items-end gap-2 text-right">
        <span class="font-mono text-xs tracking-widest uppercase">
          {
            m.achievementsSection.entries.replace(
              "{count}",
              String(credentials.length),
            )
          }
        </span>
        {
          hasMore && (
            <a
              href="/achievements"
              data-cursor="focus"
              data-cursor-label="View"
              class="font-mono text-xs tracking-[0.2em] uppercase transition-colors hover:text-accent"
            >
              {m.common.viewArchive}
            </a>
          )
        }
      </div>
    </FocusIn>
    <FocusIn
      as="h2"
      delay={80}
      class="mb-16 max-w-2xl font-display text-3xl italic leading-tight"
    >
      {m.achievementsSection.title}
    </FocusIn>

    <CredentialsGrid credentials={credentials} />
  </div>
</section>
