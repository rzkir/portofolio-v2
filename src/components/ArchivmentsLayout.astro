---
import FocusIn from "@/components/FocusIn.astro";
import CredentialsGrid from "@/components/CredentialsGrid.astro";
import { fetchAchievementsPage } from "@/utils/FetchArchivments";
import { getFeaturedCredentials } from "@/service/archivments.service";

const [credentials, meta] = await Promise.all([
  getFeaturedCredentials(),
  fetchAchievementsPage({ page: 1 }),
]);

const hasMore = meta.nextPage;
---

<section
  id="kredensial"
  class="border-t border-border bg-surface/40 px-4 py-20 md:px-6"
>
  <div class="mx-auto container px-4 md:px-6">
    <FocusIn class="mb-12 flex items-end justify-between gap-4">
      <p
        class="font-mono text-xs tracking-widest text-muted-foreground uppercase"
      >
        Kredensial / 07
      </p>
      <div class="flex flex-col items-end gap-2 text-right">
        <span
          class="font-mono text-xs tracking-widest text-muted-foreground uppercase"
        >
          {credentials.length} Entri
        </span>
        {
          hasMore && (
            <a
              href="/achievements"
              data-cursor="focus"
              data-cursor-label="View"
              class="font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase transition-colors hover:text-accent"
            >
              Lihat arsip lengkap →
            </a>
          )
        }
      </div>
    </FocusIn>
    <FocusIn
      as="h2"
      delay={80}
      class="mb-16 max-w-2xl font-display text-3xl italic leading-tight"
    >
      Pendidikan berkelanjutan — dari fundamental sampai spesialisasi.
    </FocusIn>

    <CredentialsGrid credentials={credentials} />
  </div>
</section>
