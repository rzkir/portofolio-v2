---
import FocusIn from "@/components/FocusIn.astro";
import Dialog from "@/components/ui/dialog.astro";
import CertificateIcon from "@/components/svg/certificate.astro";
import PreviewIcon from "@/components/svg/priview.astro";
import { getCredentials } from "@/service/archivments.service";

const credentials = await getCredentials();
---

<section
  id="kredensial"
  class="border-t border-border bg-surface/40 px-4 py-20 md:px-6"
>
  <div class="mx-auto container px-4 md:px-6">
    <FocusIn class="mb-12 flex items-end justify-between">
      <p
        class="font-mono text-xs tracking-widest text-muted-foreground uppercase"
      >
        Kredensial / 07
      </p>
      <span
        class="font-mono text-xs tracking-widest text-muted-foreground uppercase"
      >
        {credentials.length} Entri
      </span>
    </FocusIn>
    <FocusIn
      as="h2"
      delay={80}
      class="mb-16 max-w-2xl font-display text-3xl italic leading-tight"
    >
      Pendidikan berkelanjutan — dari fundamental sampai spesialisasi.
    </FocusIn>

    <ul
      class="grid grid-cols-1 gap-px bg-border sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        credentials.map((c, i) => {
          const dialogId = `credential-dialog-${i}`;

          return (
            <FocusIn
              as="li"
              delay={(i % 6) * 60}
              class="group bg-background p-6 transition-colors hover:bg-accent/5"
            >
              <Dialog id={dialogId} class="max-w-3xl overflow-y-auto">
                <button
                  slot="trigger"
                  type="button"
                  data-dialog-open={dialogId}
                  data-cursor="focus"
                  data-cursor-label="Verify"
                  aria-label={`Lihat sertifikat ${c.title}`}
                  class="mb-4 flex w-full flex-col items-center justify-center gap-3 rounded-md border border-border/60 bg-surface aspect-video transition-colors hover:border-accent/30 hover:bg-accent/5"
                >
                  <CertificateIcon
                    size={28}
                    class="text-muted-foreground transition-colors group-hover:text-accent"
                  />
                  <span class="inline-flex items-center gap-2 font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase transition-colors group-hover:text-accent">
                    Lihat sertifikat
                    <PreviewIcon size={12} class="opacity-60" />
                  </span>
                </button>

                <article class="px-6 py-8 sm:px-10 sm:py-10">
                  <header class="mb-6 border-b border-border pb-6">
                    <p class="mb-2 font-mono text-[10px] tracking-[0.2em] text-accent">
                      {c.code}
                    </p>
                    <h3 class="font-display text-2xl italic leading-snug sm:text-3xl">
                      {c.title}
                    </h3>
                    <p class="mt-2 text-sm text-muted-foreground">
                      {c.issuer} · {c.year}
                    </p>
                  </header>
                  <figure class="overflow-hidden rounded-md border border-border bg-surface">
                    <img
                      data-credential-src={c.imageUrl}
                      alt={c.title}
                      decoding="async"
                      class="aspect-video w-full object-contain"
                    />
                  </figure>
                </article>
              </Dialog>

              <p class="mb-4 font-mono text-[10px] tracking-[0.2em] text-accent">
                {c.code}
              </p>
              <h3 class="mb-2 font-display text-lg italic leading-snug">
                {c.title}
              </h3>
              <p class="text-xs text-muted-foreground">
                {c.issuer} · {c.year}
              </p>
            </FocusIn>
          );
        })
      }
    </ul>
  </div>
</section>

<script>
  function initCredentialImages() {
    document
      .querySelectorAll<HTMLDialogElement>('dialog[id^="credential-dialog-"]')
      .forEach((dialog) => {
        if (dialog.dataset.credentialImageInit) return;
        dialog.dataset.credentialImageInit = "true";

        dialog.addEventListener("toggle", () => {
          if (!dialog.open) return;

          const img = dialog.querySelector<HTMLImageElement>(
            "img[data-credential-src]",
          );
          if (img && !img.src) {
            img.src = img.dataset.credentialSrc ?? "";
          }
        });
      });
  }

  initCredentialImages();
  document.addEventListener("astro:page-load", initCredentialImages);
</script>
