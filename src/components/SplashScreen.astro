---
import FadeInText from "@astroanimate/core/FadeInText";

const cinematic = "cubic-bezier(0.32, 0.72, 0, 1)";
---

<div
  id="splash-screen"
  aria-hidden="true"
  data-header-theme="inverse"
  class="splash-screen fixed inset-0 z-100 flex flex-col items-center justify-center bg-accent"
>
  <div
    id="splash-content"
    class="flex flex-col items-center gap-6 transition-[transform,opacity] duration-700"
    style="transition-timing-function: var(--ease-cinematic)"
  >
    <FadeInText
      as="span"
      enhance={false}
      duration={1.1}
      delay={0}
      blur="0px"
      yOffset={24}
      easing={cinematic}
      class="font-display text-[8rem] leading-none text-background/90 italic md:text-[12rem]"
    >
      RR
    </FadeInText>

    <FadeInText
      enhance={false}
      duration={0.7}
      delay={0.35}
      blur="0px"
      yOffset={14}
      easing={cinematic}
      class="flex flex-col items-center gap-2"
    >
      <span
        class="font-mono text-xs tracking-[0.3em] text-background/70 uppercase"
        >Rizki Ramadhan</span
      >
      <span
        class="font-mono text-xs tracking-[0.3em] text-background/40 uppercase"
        >Fullstack Developer</span
      >
    </FadeInText>
  </div>

  <FadeInText
    id="splash-progress-wrap"
    enhance={false}
    duration={0.9}
    delay={0.6}
    blur="0px"
    yOffset={8}
    easing={cinematic}
    class="absolute bottom-10 left-1/2 flex -translate-x-1/2 flex-col items-center gap-3"
  >
    <span
      id="splash-progress"
      class="font-mono text-md tracking-[0.24em] text-background/50 tabular-nums"
      aria-hidden="true"
    >
      000
    </span>
    <span class="block h-px w-24 bg-background/30"></span>
  </FadeInText>
</div>

<script>
  import { bindSplashScreen } from "@/service/spleshscreen.service";

  function initSplash() {
    bindSplashScreen();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSplash, { once: true });
  } else {
    initSplash();
  }

  document.addEventListener("astro:page-load", initSplash);
</script>
