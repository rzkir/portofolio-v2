---
import FadeInText from "@astroanimate/core/FadeInText";

const cinematic = "cubic-bezier(0.32, 0.72, 0, 1)";
---

<div
  id="splash-screen"
  aria-hidden="true"
  data-header-theme="inverse"
  class="splash-screen fixed inset-0 z-100 flex flex-col items-center justify-center bg-accent"
>
  <div
    id="splash-content"
    class="flex flex-col items-center gap-6 transition-[transform,opacity] duration-700"
    style="transition-timing-function: var(--ease-cinematic)"
  >
    <FadeInText
      as="span"
      enhance={false}
      duration={1.1}
      delay={0}
      blur="0px"
      yOffset={24}
      easing={cinematic}
      class="font-display text-[8rem] leading-none text-background/90 italic md:text-[12rem]"
    >
      RR
    </FadeInText>

    <FadeInText
      enhance={false}
      duration={0.7}
      delay={0.35}
      blur="0px"
      yOffset={14}
      easing={cinematic}
      class="flex flex-col items-center gap-2"
    >
      <span
        class="font-mono text-xs tracking-[0.3em] text-background/70 uppercase"
        >Rizki Ramadhan</span
      >
      <span
        class="font-mono text-xs tracking-[0.3em] text-background/40 uppercase"
        >Fullstack Developer</span
      >
    </FadeInText>
  </div>

  <FadeInText
    id="splash-progress-wrap"
    enhance={false}
    duration={0.9}
    delay={0.6}
    blur="0px"
    yOffset={8}
    easing={cinematic}
    class="absolute bottom-10 left-1/2 flex -translate-x-1/2 flex-col items-center gap-3"
  >
    <span
      id="splash-progress"
      class="font-mono text-md tracking-[0.24em] text-background/50 tabular-nums"
      aria-hidden="true"
    >
      000
    </span>
    <span class="block h-px w-24 bg-background/30"></span>
  </FadeInText>
</div>

<style>
  .splash-screen {
    transition: transform 800ms var(--ease-cinematic);
  }

  .splash-screen.is-exiting {
    transform: translateY(-100%);
    pointer-events: none;
  }

  .splash-screen.is-exiting #splash-content {
    opacity: 0;
    transform: translateY(-16px) scale(0.97);
  }
</style>

<script>
  const HOLD_MS = 2000;
  const EXIT_MS = 400;
  const TOTAL_MS = HOLD_MS + EXIT_MS;

  let running = false;

  function unlockPage() {
    document.documentElement.classList.remove("splash-pending");
  }

  function setSplashProgress(progressEl: HTMLElement, value: number) {
    progressEl.textContent = String(Math.min(100, Math.max(0, value))).padStart(
      3,
      "0",
    );
  }

  function animateSplashProgress(progressEl: HTMLElement, startTime: number) {
    const elapsed = performance.now() - startTime;
    const ratio = Math.min(elapsed / TOTAL_MS, 1);
    setSplashProgress(progressEl, Math.round(ratio * 100));
    return ratio < 1;
  }

  function finishSplash(splash: HTMLElement) {
    try {
      sessionStorage.setItem("splash-seen", "1");
    } catch (_) {}
    unlockPage();
    document.documentElement.classList.add("splash-seen");
    splash.remove();
    running = false;
  }

  function initSplash() {
    if (running) return;

    const splash = document.getElementById("splash-screen");
    if (!splash) return;

    if (document.documentElement.classList.contains("splash-seen")) {
      splash.remove();
      return;
    }

    if (!document.documentElement.classList.contains("splash-pending")) {
      return;
    }

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      finishSplash(splash);
      return;
    }

    running = true;

    let exitTimer = 0;
    let doneTimer = 0;
    let progressRaf = 0;
    const progressEl = document.getElementById("splash-progress");

    const startSequence = () => {
      if (progressEl) {
        const startTime = performance.now();
        const tickProgress = () => {
          if (!progressEl) return;
          if (animateSplashProgress(progressEl, startTime)) {
            progressRaf = requestAnimationFrame(tickProgress);
          }
        };
        progressRaf = requestAnimationFrame(tickProgress);
      }

      exitTimer = window.setTimeout(() => {
        unlockPage();
        splash.classList.add("is-exiting");
      }, HOLD_MS);

      doneTimer = window.setTimeout(() => {
        if (progressEl) setSplashProgress(progressEl, 100);
        finishSplash(splash);
      }, TOTAL_MS);
    };

    requestAnimationFrame(startSequence);

    document.addEventListener(
      "astro:before-preparation",
      () => {
        window.clearTimeout(exitTimer);
        window.clearTimeout(doneTimer);
        cancelAnimationFrame(progressRaf);
        running = false;
      },
      { once: true },
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSplash, { once: true });
  } else {
    initSplash();
  }

  document.addEventListener("astro:page-load", initSplash);
</script>
