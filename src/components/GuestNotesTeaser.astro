---
import FocusIn from "@/components/FocusIn.astro";
import { getProviderLabel } from "@/lib/guest-note-providers";
import { getLocale, getMessages } from "@/lib/i18n";
import { getGuestNotes } from "@/service/noted.service";

const locale = getLocale(Astro);
const m = getMessages(locale);

const notes = await getGuestNotes();
const preview = notes.slice(0, 2);
const noteCount = String(notes.length).padStart(2, "0");
---

<section
  id="catatan"
  class="border-t border-border bg-surface/40 py-20"
  aria-label={m.guestNotesTeaser.aria}
>
  <div class="mx-auto container px-4 md:px-6">
    <FocusIn class="grid items-end gap-12 md:grid-cols-12">
      <div class="md:col-span-7">
        <p class="mb-4 font-mono text-xs tracking-[0.2em] uppercase">
          {m.guestNotesTeaser.eyebrow.replace("{count}", noteCount)}
        </p>
        <h2
          class="mb-6 max-w-xl font-display text-4xl italic leading-tight md:text-5xl"
        >
          {m.guestNotesTeaser.title}
        </h2>
        <p class="max-w-md text-pretty text-sm leading-relaxed">
          {m.guestNotesTeaser.body}
        </p>
      </div>

      <div class="flex flex-wrap gap-3 md:col-span-5 md:justify-end">
        <a
          href="/guest-notes"
          data-cursor="focus"
          data-cursor-label="Open"
          class="rounded-full bg-foreground px-8 py-4 text-sm font-medium text-background transition-colors hover:bg-accent"
        >
          {m.common.openGuestBook}
        </a>
      </div>
    </FocusIn>

    {
      preview.length > 0 && (
        <FocusIn class="mt-16 grid gap-4 md:grid-cols-2" delay={120}>
          {preview.map((note) => (
            <figure class="border border-border bg-background p-6 transition-colors hover:border-accent/40">
              <blockquote class="mb-4 font-display text-xl leading-snug italic">
                <span class="text-accent">“</span>
                {note.message}
                <span class="text-accent">”</span>
              </blockquote>
              <figcaption class="flex flex-wrap items-center gap-x-2 gap-y-1 border-t border-border pt-4 font-mono text-xs tracking-[0.18em] uppercase">
                <span class="text-foreground/80">— {note.name}</span>
                <span aria-hidden="true">·</span>
                <span>{getProviderLabel(note.provider)}</span>
              </figcaption>
            </figure>
          ))}
        </FocusIn>
      )
    }
  </div>
</section>
