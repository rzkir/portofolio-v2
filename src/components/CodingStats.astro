---
import CountUp from "@astroanimate/core/CountUp";
import FocusIn from "@/components/FocusIn.astro";
import {
  codingLanguages,
  codingStats,
  codingStreaks,
  codingTrophies,
  heatmapOpacity,
  heatmapValues,
  leetcodeSolved,
} from "@/data/portfolio";

const leetcodeTone: Record<string, string> = {
  Easy: "text-emerald-200",
  Medium: "text-amber-200",
  Hard: "text-red-300",
};

const countUpClass =
  "font-display text-5xl italic font-normal text-background md:text-6xl";
const countUpSmClass = "font-display text-3xl italic font-normal text-background";

function parseStatValue(raw: string) {
  const match = raw.match(/^(\D*)(\d+)(\D*)$/);
  if (!match) return null;

  return {
    prefix: match[1] ?? "",
    value: Number(match[2]),
    suffix: match[3] ?? "",
  };
}
---

<section
  class="coding-stats bg-accent px-4 py-20 text-background md:px-6"
  data-header-theme="inverse"
>
  <div class="mx-auto container px-4 md:px-6">
    <FocusIn class="mb-16 flex items-end justify-between">
      <div>
        <p
          class="mb-4 font-mono text-xs tracking-widest text-background/50 uppercase"
        >
          Coding Stats / 10
        </p>
        <h2
          class="font-display text-5xl leading-tight text-background italic md:text-6xl"
        >
          Metrik yang terukur.
        </h2>
      </div>
      <span
        class="hidden font-mono text-xs tracking-widest text-background/50 uppercase md:block"
        >Update · 2026</span
      >
    </FocusIn>

    <div
      class="mb-20 grid grid-cols-2 gap-px border-y border-background/20 bg-background/20 md:grid-cols-4"
    >
      {
        codingStats.map((s, i) => {
          const parsed = parseStatValue(s.value);

          return (
            <FocusIn class="bg-accent p-8 md:p-10" delay={i * 90}>
              <p class="mb-3 font-mono text-xs tracking-widest text-background/50 uppercase">
                {s.label}
              </p>
              {parsed ? (
                <CountUp
                  enhance
                  value={parsed.value}
                  prefix={parsed.prefix}
                  suffix={parsed.suffix}
                  duration={1600}
                  mainClassName={countUpClass}
                  fontSize="inherit"
                  fontFamily="inherit"
                  textColor="inherit"
                />
              ) : (
                <p class="font-display text-5xl italic text-background md:text-6xl">
                  {s.value}
                </p>
              )}
              <p class="mt-2 font-mono text-xs tracking-widest text-background/50 uppercase">
                {s.sub}
              </p>
            </FocusIn>
          );
        })
      }
    </div>

    <div class="grid gap-16 lg:grid-cols-2">
      <div>
        <FocusIn class="mb-6 flex items-center justify-between" delay={40}>
          <p
            class="font-mono text-xs tracking-widest text-background/50 uppercase"
          >
            Kontribusi 52 Minggu
          </p>
          <span
            class="font-mono text-xs tracking-widest text-background/50 uppercase"
            >GitHub</span
          >
        </FocusIn>

        <FocusIn class="rounded border border-background/20 p-5" delay={80}>
          <div class="grid grid-cols-[repeat(52,minmax(0,1fr))] gap-[3px]">
            {
              heatmapValues.map((v, i) => (
                <div
                  class="coding-stats__heatmap-cell aspect-square w-full rounded-full bg-background"
                  style={`--i: ${i}; --cell-opacity: ${heatmapOpacity(v)}`}
                />
              ))
            }
          </div>
          <div class="mt-4 flex items-center justify-between">
            <span class="font-mono text-xs tracking-widest text-background/50"
              >Jun 2025</span
            >
            <div class="flex items-center gap-1.5">
              <span class="font-mono text-xs tracking-widest text-background/50"
                >Less</span
              >
              {
                [0.1, 0.3, 0.55, 0.85].map((o) => (
                  <div
                    class="size-2 rounded-full bg-background"
                    style={`opacity: ${o}`}
                  />
                ))
              }
              <span class="font-mono text-xs tracking-widest text-background/50"
                >More</span
              >
            </div>
            <span class="font-mono text-xs tracking-widest text-background/50"
              >Jun 2026</span
            >
          </div>
        </FocusIn>

        <div class="mt-8 grid grid-cols-2 gap-6">
          {
            codingStreaks.map((st, i) => {
              const parsed = parseStatValue(st.value);

              return (
                <FocusIn
                  class="border-t border-background/20 pt-5"
                  delay={120 + i * 100}
                >
                  <p class="mb-2 font-mono text-xs tracking-widest text-background/50 uppercase">
                    {st.label}
                  </p>
                  {parsed ? (
                    <CountUp
                      enhance
                      value={parsed.value}
                      prefix={parsed.prefix}
                      suffix={parsed.suffix}
                      duration={1400}
                      mainClassName={countUpSmClass}
                      fontSize="inherit"
                      fontFamily="inherit"
                      textColor="inherit"
                    />
                  ) : (
                    <p class="font-display text-3xl italic text-background">
                      {st.value}
                    </p>
                  )}
                  <p class="mt-1 font-mono text-xs tracking-widest text-background/60">
                    {st.desc}
                  </p>
                </FocusIn>
              );
            })
          }
        </div>
      </div>

      <div>
        <FocusIn class="mb-6 flex items-center justify-between" delay={40}>
          <p
            class="font-mono text-xs tracking-widest text-background/50 uppercase"
          >
            Distribusi Bahasa
          </p>
          <span
            class="font-mono text-xs tracking-widest text-background/50 uppercase"
            >GitHub</span
          >
        </FocusIn>

        <div class="space-y-5">
          {
            codingLanguages.map((lang, i) => (
              <FocusIn delay={80 + i * 70}>
                <div class="mb-2 flex items-center justify-between">
                  <span class="font-mono text-xs text-background/90">
                    {lang.name}
                  </span>
                  <span class="font-mono text-xs tracking-widest text-background/50">
                    {lang.pct}%
                  </span>
                </div>
                <div class="h-1 w-full bg-background/15">
                  <div
                    class="coding-stats__bar-fill h-full bg-background"
                    style={`--pct: ${lang.pct}%`}
                  />
                </div>
              </FocusIn>
            ))
          }
        </div>

        <FocusIn class="mt-12 border-t border-background/20 pt-10" delay={100}>
          <div class="mb-6 flex items-center justify-between">
            <p
              class="font-mono text-xs tracking-widest text-background/50 uppercase"
            >
              Problem Solved
            </p>
            <span
              class="font-mono text-xs tracking-widest text-background/50 uppercase"
              >LeetCode</span
            >
          </div>
          <div class="grid grid-cols-3 gap-px bg-background/20">
            {
              leetcodeSolved.map((d, i) => {
                const parsed = parseStatValue(d.value);

                return (
                  <FocusIn
                    class="bg-accent p-6 text-center"
                    delay={140 + i * 80}
                  >
                    {parsed ? (
                      <CountUp
                        enhance
                        value={parsed.value}
                        duration={1200}
                        mainClassName={`${countUpSmClass} ${leetcodeTone[d.label] ?? "text-background"}`}
                        fontSize="inherit"
                        fontFamily="inherit"
                        textColor="inherit"
                      />
                    ) : (
                      <p
                        class:list={[
                          "font-display text-3xl italic",
                          leetcodeTone[d.label] ?? "text-background",
                        ]}
                      >
                        {d.value}
                      </p>
                    )}
                    <p class="mt-2 font-mono text-xs tracking-widest text-background/50 uppercase">
                      {d.label}
                    </p>
                  </FocusIn>
                );
              })
            }
          </div>
        </FocusIn>

        <FocusIn
          class="mt-12 border-t border-background/20 pt-10"
          delay={120}
        >
          <p
            class="mb-6 font-mono text-xs tracking-widest text-background/50 uppercase"
          >
            Pencapaian
          </p>
          <div class="flex flex-wrap gap-4">
            {
              codingTrophies.map((t, i) => (
                <FocusIn
                  class="inline-flex items-center gap-2 rounded-full border border-background/25 bg-background/10 px-4 py-2 font-mono text-[10px] tracking-wider text-background/85 uppercase"
                  delay={160 + i * 60}
                >
                  <span class="size-1.5 rounded-full bg-background/70" />
                  {t}
                </FocusIn>
              ))
            }
          </div>
        </FocusIn>
      </div>
    </div>
  </div>
</section>

<style>
  .coding-stats__bar-fill {
    width: 0;
    transition: width 1.1s var(--ease-cinematic);
  }

  .coding-stats
    [data-astro-fade-in-text][data-state="animate"]
    .coding-stats__bar-fill {
    width: var(--pct);
  }

  .coding-stats__heatmap-cell {
    opacity: 0;
    transform: scale(0.45);
  }

  .coding-stats
    [data-astro-fade-in-text][data-state="animate"]
    .coding-stats__heatmap-cell {
    animation: coding-stats-dot-in 0.38s var(--ease-cinematic) forwards;
    animation-delay: calc(var(--i) * 3ms);
  }

  @keyframes coding-stats-dot-in {
    to {
      opacity: var(--cell-opacity);
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .coding-stats__bar-fill {
      width: var(--pct) !important;
      transition: none !important;
    }

    .coding-stats__heatmap-cell {
      opacity: var(--cell-opacity) !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>
