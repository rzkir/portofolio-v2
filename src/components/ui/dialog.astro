---
import { cn } from "@/lib/utiles";

interface Props {
  id: string;
  class?: string;
}

const { id, class: className } = Astro.props;
---

<slot name="trigger" />

<dialog
  id={id}
  data-dialog
  class={cn(
    "fixed inset-0 z-50 m-auto max-h-[90vh] w-[calc(100%-2rem)] border border-border bg-background p-0 shadow-lg backdrop:bg-foreground/40 open:animate-in open:fade-in-0 sm:rounded-sm",
    className,
  )}
>
  <button
    type="button"
    data-dialog-close
    class="absolute top-4 right-4 z-10 flex size-8 items-center justify-center rounded-sm font-mono text-sm text-muted-foreground transition-colors hover:bg-surface hover:text-foreground"
    aria-label="Tutup dialog"
  >
    ✕
  </button>
  <slot />
</dialog>

<style>
  html.dialog-open,
  html.dialog-open body {
    overflow: hidden;
  }
</style>

<script>
  let openDialogCount = 0;

  function lockScroll() {
    openDialogCount += 1;
    document.documentElement.classList.add("dialog-open");
  }

  function unlockScroll() {
    openDialogCount = Math.max(0, openDialogCount - 1);
    if (openDialogCount === 0) {
      document.documentElement.classList.remove("dialog-open");
    }
  }

  function initDialogs() {
    document.querySelectorAll<HTMLElement>("[data-dialog-open]").forEach((trigger) => {
      if (trigger.dataset.dialogBound) return;
      trigger.dataset.dialogBound = "true";

      trigger.addEventListener("click", () => {
        const id = trigger.getAttribute("data-dialog-open");
        const dialog = document.getElementById(id ?? "");
        if (dialog instanceof HTMLDialogElement && !dialog.open) {
          dialog.showModal();
          lockScroll();
        }
      });
    });

    document.querySelectorAll("dialog[data-dialog]").forEach((el) => {
      if (!(el instanceof HTMLDialogElement)) return;
      if (el.dataset.dialogInit) return;
      el.dataset.dialogInit = "true";

      el.addEventListener("close", () => {
        unlockScroll();
      });

      el.addEventListener("click", (event) => {
        if (event.target === el) {
          el.close();
        }
      });

      el.querySelectorAll("[data-dialog-close]").forEach((btn) => {
        btn.addEventListener("click", () => el.close());
      });
    });
  }

  initDialogs();
  document.addEventListener("astro:page-load", initDialogs);
</script>
