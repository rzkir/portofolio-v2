---
import { cn } from "@/lib/utiles";
import { prepareContentHtml } from "@/lib/sanitize-content-html";

interface Props {
  content: string;
  class?: string;
}

const { content, class: className } = Astro.props;
const html = prepareContentHtml(content);
---

<article class={cn("prose-editorial", className)} set:html={html} />
