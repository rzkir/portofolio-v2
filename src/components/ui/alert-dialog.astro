---
import { cn } from "@/lib/utiles";
import Spiner from "@/components/ui/spiner.astro";

interface Props {
  id: string;
  title: string;
  description?: string;
  confirmLabel?: string;
  cancelLabel?: string;
  loadingLabel?: string;
  class?: string;
}

const {
  id,
  title,
  description,
  confirmLabel = "Confirm",
  cancelLabel = "Cancel",
  loadingLabel = "Loading…",
  class: className,
} = Astro.props;
---

<dialog
  id={id}
  data-alert-dialog
  class={cn(
    "fixed inset-0 z-50 m-auto max-h-[90vh] w-[calc(100%-2rem)] max-w-md border border-border bg-background p-0 shadow-lg backdrop:bg-foreground/40 open:animate-in open:fade-in-0 sm:rounded-sm",
    className,
  )}
>
  <div class="relative px-6 py-8 sm:px-8" data-alert-dialog-body>
    <h2 class="font-display text-2xl tracking-tight text-foreground">
      {title}
    </h2>
    {
      description && (
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          {description}
        </p>
      )
    }
    <div class="mt-8 flex justify-end gap-4" data-alert-dialog-actions>
      <button
        type="button"
        data-alert-dialog-cancel
        class="font-mono text-xs tracking-[0.2em] text-muted-foreground uppercase transition-colors hover:text-foreground disabled:opacity-50"
      >
        {cancelLabel}
      </button>
      <button
        type="button"
        data-alert-dialog-confirm
        class="font-mono text-xs tracking-[0.2em] text-destructive uppercase transition-colors hover:text-destructive/80 disabled:opacity-50"
      >
        {confirmLabel}
      </button>
    </div>

    <div
      data-alert-dialog-loading
      class="absolute inset-0 z-10 hidden flex-col items-center justify-center gap-4 bg-background/85"
      aria-hidden="true"
    >
      <Spiner size="lg" label={loadingLabel} />
      <span class="font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase">
        {loadingLabel}
      </span>
    </div>
  </div>
</dialog>

<style>
  html.alert-dialog-open,
  html.alert-dialog-open body {
    overflow: hidden;
  }
</style>

<script>
  import { registerAlertDialogSystem } from "@/lib/alert-dialog";

  registerAlertDialogSystem();
</script>
