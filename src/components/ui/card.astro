---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import PreviewIcon from "@/components/svg/priview.astro";
import { cn } from "@/lib/utiles";

export interface CardProps {
  no: string;
  title: string;
  tag: string;
  year: string;
  image: ImageMetadata | string;
  href: string;
}

interface Props extends CardProps {
  class?: string;
}

const { no, title, tag, year, image, href, class: className } = Astro.props;
const isRemoteImage = typeof image === "string";
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  data-cursor="focus"
  data-cursor-label="Open"
  aria-label={`Preview ${title}`}
  class={cn("ui-card group", className)}
>
  <figure class="ui-card__thumb">
    {
      isRemoteImage ? (
        <img
          src={image}
          alt=""
          loading="lazy"
          decoding="async"
          class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <Image
          src={image}
          alt=""
          class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      )
    }
  </figure>

  <div class="ui-card__body">
    <div class="ui-card__meta">
      <span
        class="ui-card__no font-mono text-[10px] uppercase tracking-[0.2em] text-accent"
      >
        {no}
      </span>
      <span
        class="ui-card__year font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
      >
        {year}
      </span>
    </div>

    <h2 class="ui-card__title font-display italic leading-tight">
      {title}
    </h2>

    <p
      class="ui-card__tag font-mono text-[10px] uppercase tracking-[0.14em] text-muted-foreground"
    >
      {tag}
    </p>

    <span class="ui-card__cta">
      <PreviewIcon
        size={14}
        class="text-muted-foreground opacity-40 transition-all group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-accent group-hover:opacity-100"
      />
    </span>
  </div>
</a>

<style>
  /* —— List (flex column) —— */
  :global(.works-archive[data-view="list"]) .ui-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
    transition: background-color 0.2s var(--ease-cinematic);
  }

  @media (min-width: 640px) {
    :global(.works-archive[data-view="list"]) .ui-card {
      gap: 1.5rem;
      padding: 1.25rem 0;
    }
  }

  :global(.works-archive[data-view="list"]) .ui-card:hover {
    background-color: color-mix(in oklch, var(--surface) 60%, transparent);
  }

  :global(.works-archive[data-view="list"]) .ui-card__thumb {
    width: 4rem;
    height: 4rem;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 0.375rem;
    background-color: var(--surface);
  }

  @media (min-width: 640px) {
    :global(.works-archive[data-view="list"]) .ui-card__thumb {
      width: 5rem;
      height: 5rem;
    }
  }

  :global(.works-archive[data-view="list"]) .ui-card__body {
    display: grid;
    min-width: 0;
    flex: 1;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.25rem 1rem;
  }

  @media (min-width: 640px) {
    :global(.works-archive[data-view="list"]) .ui-card__body {
      grid-template-columns: 3rem 1fr auto auto;
    }
  }

  :global(.works-archive[data-view="list"]) .ui-card__meta {
    display: contents;
  }

  :global(.works-archive[data-view="list"]) .ui-card__no {
    display: none;
  }

  @media (min-width: 640px) {
    :global(.works-archive[data-view="list"]) .ui-card__no {
      display: block;
      grid-column: 1;
      grid-row: 1 / 3;
      align-self: center;
    }
  }

  :global(.works-archive[data-view="list"]) .ui-card__title {
    grid-column: 1;
    font-size: 1.125rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (min-width: 640px) {
    :global(.works-archive[data-view="list"]) .ui-card__title {
      grid-column: 2;
      font-size: 1.25rem;
    }
  }

  :global(.works-archive[data-view="list"]) .ui-card__tag {
    grid-column: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (min-width: 640px) {
    :global(.works-archive[data-view="list"]) .ui-card__tag {
      grid-column: 2;
    }
  }

  :global(.works-archive[data-view="list"]) .ui-card__year {
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    align-self: start;
  }

  @media (min-width: 640px) {
    :global(.works-archive[data-view="list"]) .ui-card__year {
      grid-column: 3;
      grid-row: 1 / 3;
      align-self: center;
      justify-self: end;
    }
  }

  :global(.works-archive[data-view="list"]) .ui-card__cta {
    grid-column: 2;
    grid-row: 2;
    justify-self: end;
    align-self: end;
  }

  @media (min-width: 640px) {
    :global(.works-archive[data-view="list"]) .ui-card__cta {
      grid-column: 4;
      grid-row: 1 / 3;
      align-self: center;
    }
  }

  /* —— Grid —— */
  :global(.works-archive[data-view="grid"]) .ui-card {
    display: flex;
    height: 100%;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background-color: var(--background);
    transition:
      border-color 0.25s var(--ease-cinematic),
      background-color 0.25s var(--ease-cinematic);
  }

  :global(.works-archive[data-view="grid"]) .ui-card:hover {
    border-color: color-mix(in oklch, var(--accent) 35%, var(--border));
    background-color: color-mix(in oklch, var(--surface) 50%, transparent);
  }

  :global(.works-archive[data-view="grid"]) .ui-card__thumb {
    aspect-ratio: 16 / 10;
    width: 100%;
    overflow: hidden;
    background-color: var(--surface);
  }

  :global(.works-archive[data-view="grid"]) .ui-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.25rem 1.25rem;
  }

  :global(.works-archive[data-view="grid"]) .ui-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  :global(.works-archive[data-view="grid"]) .ui-card__title {
    font-size: 1.25rem;
    line-height: 1.2;
  }

  :global(.works-archive[data-view="grid"]) .ui-card__tag {
    flex: 1;
    line-height: 1.4;
  }

  :global(.works-archive[data-view="grid"]) .ui-card__cta {
    margin-top: auto;
    padding-top: 0.5rem;
  }
</style>
