---
import { Image } from "astro:assets";
import FocusIn from "@/components/FocusIn.astro";
import { getWorks, getWorksScrollVh } from "@/service/works.service";

const works = getWorks();
const scrollVh = getWorksScrollVh(works.length);
---

<section
  id="karya"
  data-works-scroll
  data-header-theme="inverse"
  class="works-scroll relative bg-foreground text-background"
  aria-label="Karya pilihan"
>
  <div class="works-scroll__intro relative container px-4 pt-20 pb-12 md:px-6 md:pt-24">
    <FocusIn>
      <div class="flex items-end justify-between">
        <div>
          <p
            class="mb-4 font-mono text-[10px] uppercase tracking-[0.2em] opacity-50"
          >
            Karya Pilihan / 02
          </p>
          <h2 class="font-display text-5xl italic">Featured Works</h2>
        </div>
        <span
          class="hidden font-mono text-[10px] uppercase tracking-[0.2em] opacity-50 md:block"
        >
          Scroll untuk menjelajah
        </span>
      </div>
    </FocusIn>
  </div>

  <div
    data-works-stage
    class="works-scroll__stage relative"
    style={`height: ${scrollVh}vh`}
  >
    <div class="works-scroll__pin sticky top-0 flex h-screen flex-col overflow-hidden">
      <div class="works-scroll__viewport relative min-h-0 flex-1 overflow-hidden">
      <div
        data-works-track
        class="works-scroll__track flex flex-col will-change-transform"
      >
        {
          works.map((work, i) => (
            <article
              data-works-slide
              data-index={i}
              class={`group grid h-full shrink-0 grid-cols-1 items-center gap-12 px-4 pb-16 md:grid-cols-12 md:px-6 ${i % 2 === 1 ? "md:[&>figure]:order-2" : ""}`}
            >
              <figure
                data-cursor="grab"
                class="container overflow-hidden rounded-lg bg-background/5 md:col-span-7"
              >
                <Image
                  src={work.image}
                  alt={work.title}
                  class="aspect-video w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                />
              </figure>
              <div
                class={`container md:col-span-5 ${i % 2 === 1 ? "md:text-right" : ""}`}
              >
                <p class="mb-4 font-mono text-xs text-accent">
                  {work.no} · {work.tag}
                </p>
                <h3 class="mb-4 font-display text-3xl italic md:text-4xl">
                  {work.title}
                </h3>
                <p class="max-w-sm text-sm leading-relaxed text-background/60 md:text-base">
                  {work.desc}
                </p>
                <p class="mt-6 font-mono text-[10px] uppercase tracking-[0.2em] opacity-40">
                  {work.year}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div
      class="container flex shrink-0 items-center gap-4 px-4 pb-8 md:px-6"
    >
      <div class="h-px flex-1 bg-background/15">
        <div
          data-works-bar
          class="h-full w-0 origin-left bg-accent transition-[width] duration-150"
        ></div>
      </div>
      <p
        data-works-counter
        class="font-mono text-[10px] uppercase tracking-[0.2em] opacity-60"
      >
        01 / {String(works.length).padStart(2, "0")}
      </p>
    </div>
    </div>
  </div>
</section>

<style>
  .works-scroll__viewport {
    height: 100%;
    overflow: hidden;
  }

  .works-scroll__track {
    height: 100%;
  }

  .works-scroll__track [data-works-slide] {
    height: 100%;
    min-height: 100%;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .works-scroll__stage {
      height: auto !important;
    }

    .works-scroll__pin {
      position: relative !important;
      height: auto !important;
    }

    .works-scroll__viewport {
      height: auto !important;
      overflow: visible !important;
    }

    .works-scroll__track {
      transform: none !important;
    }

    .works-scroll__track [data-works-slide] {
      height: auto !important;
      padding-bottom: 5rem;
    }

    [data-works-bar] {
      display: none;
    }
  }
</style>

<script>
  function initWorksScroll() {
    const section = document.querySelector<HTMLElement>("[data-works-scroll]");
    if (!section || section.dataset.bound === "true") return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      return;
    }

    section.dataset.bound = "true";

    const track = section.querySelector<HTMLElement>("[data-works-track]");
    const bar = section.querySelector<HTMLElement>("[data-works-bar]");
    const counter = section.querySelector<HTMLElement>("[data-works-counter]");
    const slides = section.querySelectorAll<HTMLElement>("[data-works-slide]");
    const count = slides.length;

    if (!track || count <= 1) return;

    const viewport = section.querySelector<HTMLElement>(".works-scroll__viewport");
    const stage = section.querySelector<HTMLElement>("[data-works-stage]");
    if (!viewport || !stage) return;

    let ticking = false;
    let slideHeight = 0;

    const layoutSlides = () => {
      slideHeight = viewport.clientHeight;
      if (slideHeight <= 0) return;

      track.style.height = `${slideHeight * count}px`;
      slides.forEach((slide) => {
        slide.style.height = `${slideHeight}px`;
        slide.style.minHeight = `${slideHeight}px`;
      });
    };

    const getSlideOffset = (progress: number) => {
      const maxIndex = count - 1;
      if (maxIndex === 0) return { offset: 0, index: 0 };

      const segmentSize = 1 / maxIndex;
      const scaled = progress / segmentSize;
      const baseIndex = Math.min(maxIndex, Math.floor(scaled + 0.0001));
      const local = scaled - baseIndex;

      // Tahan slide saat ini; transisi ke berikutnya hanya di akhir segment scroll
      const transitionStart = 0.82;
      let visualIndex = baseIndex;

      if (local > transitionStart && baseIndex < maxIndex) {
        const t = (local - transitionStart) / (1 - transitionStart);
        visualIndex = baseIndex + t;
      }

      return {
        offset: visualIndex * slideHeight,
        index: Math.min(maxIndex, Math.floor(visualIndex + 1e-6)),
      };
    };

    const update = () => {
      ticking = false;
      if (slideHeight <= 0) return;

      const rect = stage.getBoundingClientRect();
      const stageTop = window.scrollY + rect.top;
      const scrollRange = stage.offsetHeight - window.innerHeight;

      if (scrollRange <= 0) return;

      const progress = Math.min(
        Math.max((window.scrollY - stageTop) / scrollRange, 0),
        1,
      );

      const { offset, index } = getSlideOffset(progress);

      track.style.transform = `translate3d(0, ${-offset}px, 0)`;

      if (bar) {
        bar.style.width = `${((index + 1) / count) * 100}%`;
      }

      if (counter) {
        counter.textContent = `${String(index + 1).padStart(2, "0")} / ${String(count).padStart(2, "0")}`;
      }
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    layoutSlides();
    requestUpdate();

    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener(
      "resize",
      () => {
        layoutSlides();
        requestUpdate();
      },
      { passive: true },
    );

    document.addEventListener(
      "astro:before-preparation",
      () => {
        window.removeEventListener("scroll", requestUpdate);
        window.removeEventListener("resize", requestUpdate);
        section.dataset.bound = "false";
      },
      { once: true },
    );
  }

  initWorksScroll();
  document.addEventListener("astro:page-load", initWorksScroll);
</script>
