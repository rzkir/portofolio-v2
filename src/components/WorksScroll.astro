---
import { Image } from "astro:assets";
import FocusIn from "@/components/FocusIn.astro";
import PreviewIcon from "@/components/svg/priview.astro";
import { getWorks, getWorksScrollVh } from "@/service/works.service";

const works = getWorks();
const scrollVh = getWorksScrollVh(works.length);
---

<section
  id="karya"
  data-works-scroll
  data-header-theme="inverse"
  class="works-scroll relative isolate bg-accent text-background"
  aria-label="Karya pilihan"
>
  <div class="works-scroll__grid pointer-events-none absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <div class="container relative mx-auto h-full px-4 md:px-6">
      <span class="absolute inset-y-0 left-4 w-px md:left-6"></span>
      <span class="absolute inset-y-0 right-4 w-px md:right-6"></span>
    </div>
  </div>

  <div
    class="works-scroll__intro relative z-10 container border-b border-background/10 px-4 pt-20 pb-12 md:px-6 md:pt-24"
  >
    <FocusIn>
      <div class="flex items-end justify-between">
        <div>
          <p
            class="mb-4 font-mono text-[10px] uppercase tracking-[0.2em] opacity-50"
          >
            Karya Pilihan / 02
          </p>
          <h2 class="font-display text-5xl italic">Featured Works</h2>
        </div>
        <span
          class="hidden font-mono text-[10px] uppercase tracking-[0.2em] opacity-50 md:block"
        >
          Scroll untuk menjelajah
        </span>
      </div>
    </FocusIn>
  </div>

  <div
    data-works-stage
    class="works-scroll__stage relative z-10"
    style={`height: ${scrollVh}vh`}
  >
    <div
      class="works-scroll__pin sticky top-0 flex h-screen flex-col overflow-hidden"
    >
      <div
        class="works-scroll__viewport relative min-h-0 flex-1 overflow-hidden"
      >
        <div
          data-works-track
          class="works-scroll__track flex flex-col will-change-transform"
        >
          {
            works.map((work, i) => (
              <article
                data-works-slide
                data-index={i}
                class={`group grid h-full min-h-0 shrink-0 grid-cols-1 items-center gap-12 px-4 md:grid-cols-12 md:px-6 ${i % 2 === 1 ? "md:[&>figure]:order-2" : ""}`}
              >
                <figure
                  data-cursor="grab"
                  class="container overflow-hidden rounded-lg bg-background/10 md:col-span-7"
                >
                  <Image
                    src={work.image}
                    alt={work.title}
                    class="aspect-video w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                  />
                </figure>
                <div
                  class={`container md:col-span-5 ${i % 2 === 1 ? "md:text-right" : ""}`}
                >
                  <p
                    class={`mb-1 max-w-sm font-display text-5xl leading-none italic text-background/25 md:text-6xl ${i % 2 === 1 ? "md:ml-auto" : ""}`}
                    aria-hidden="true"
                  >
                    {work.no}
                  </p>
                  <span class="sr-only">Karya {work.no}</span>
                  <div
                    class={`mb-5 flex max-w-sm items-center justify-between gap-4 font-mono text-xs ${i % 2 === 1 ? "md:ml-auto" : ""}`}
                  >
                    <span class="text-background/90">{work.tag}</span>
                    <span
                      class="text-[10px] uppercase tracking-[0.2em] text-background/45"
                    >
                      {work.year}
                    </span>
                  </div>
                  <h3 class="mb-4 font-display text-3xl italic md:text-4xl">
                    {work.title}
                  </h3>
                  <p class="max-w-sm text-sm leading-relaxed text-background/60 md:text-base">
                    {work.desc}
                  </p>
                  <div class={`mt-8 ${i % 2 === 1 ? "md:flex md:justify-end" : ""}`}>
                    <a
                      href={work.previewUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      data-cursor="focus"
                      data-cursor-label="Open"
                      aria-label={`Preview ${work.title}`}
                      class="group/cta inline-flex items-center gap-2 border-b border-background/40 pb-0.5 font-mono text-[10px] uppercase tracking-[0.2em] text-background transition-colors hover:border-background"
                    >
                      Preview
                      <PreviewIcon
                        size={14}
                        class="transition-transform group-hover/cta:translate-x-0.5 group-hover/cta:-translate-y-0.5"
                      />
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <div class="container flex shrink-0 items-center gap-4 px-4 pb-8 md:px-6">
        <div class="h-px flex-1 bg-background/20">
          <div data-works-bar class="h-full w-0 origin-left bg-background"></div>
        </div>
        <p
          data-works-counter
          class="font-mono text-[10px] uppercase tracking-[0.2em] opacity-60"
        >
          01 / {String(works.length).padStart(2, "0")}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .works-scroll__grid span {
    background-color: color-mix(in oklch, var(--background) 11%, transparent);
  }

  .works-scroll__viewport {
    height: 100%;
    overflow: hidden;
  }

  .works-scroll__track {
    height: 100%;
    backface-visibility: hidden;
  }

  .works-scroll__track [data-works-slide] {
    height: 100%;
    min-height: 100%;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .works-scroll__stage {
      height: auto !important;
    }

    .works-scroll__pin {
      position: relative !important;
      height: auto !important;
    }

    .works-scroll__viewport {
      height: auto !important;
      overflow: visible !important;
    }

    .works-scroll__track {
      transform: none !important;
    }

    .works-scroll__track [data-works-slide] {
      height: auto !important;
      padding-bottom: 5rem;
    }

    [data-works-bar] {
      display: none;
    }
  }
</style>

<script>
  import { bindWorksScroll } from "@/service/works.service";

  bindWorksScroll();
  document.addEventListener("astro:page-load", () => bindWorksScroll());
</script>
