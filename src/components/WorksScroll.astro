---
import FadeInText from "@astroanimate/core/FadeInText";
import ScaleIn from "@astroanimate/core/ScaleIn";
import { Image } from "astro:assets";
import FocusIn from "@/components/FocusIn.astro";
import PreviewIcon from "@/components/svg/priview.astro";
import { getFeaturedWorks } from "@/service/works-archive.service";
import { getWorksScrollVh } from "@/service/works.service";
import { getLocale, getMessages } from "@/lib/i18n";

const locale = getLocale(Astro);
const m = getMessages(locale);

const works = await getFeaturedWorks();
const scrollVh = getWorksScrollVh(works.length);
const cinematic = "cubic-bezier(0.32, 0.72, 0, 1)";
const inViewMargin = "-12%";
---

<section
  id="karya"
  data-works-scroll
  data-header-theme="inverse"
  class="works-scroll relative isolate bg-accent text-background"
  aria-label={m.worksScroll.aria}
>
  <div class="relative mx-auto container px-4 md:px-6">
    <div
      class="works-scroll__grid pointer-events-none absolute inset-0 z-0 overflow-hidden"
      aria-hidden="true"
    >
      <span class="absolute inset-y-0 left-4 w-px md:left-6"></span>
      <span class="absolute inset-y-0 right-4 w-px md:right-6"></span>
    </div>

    <div
      class="works-scroll__intro relative z-10 border-b border-background/10 pt-20 pb-12 md:pt-24"
    >
      <FocusIn>
        <div class="flex items-end justify-between">
          <div>
            <p
              class="mb-4 font-mono text-sm tracking-widest text-gray-300 uppercase"
            >
              {m.worksScroll.eyebrow}
            </p>
            <h2 class="font-display text-5xl italic">{m.worksScroll.title}</h2>
          </div>
          <div class="hidden flex-col items-end gap-3 md:flex">
            <span
              class="font-mono text-sm tracking-widest text-gray-300 uppercase"
            >
              {m.worksScroll.scrollHint}
            </span>
            <a
              href="/works"
              data-cursor="focus"
              data-cursor-label="View"
              class="font-mono text-[10px] uppercase tracking-[0.2em] text-background/70 transition-colors hover:text-background"
            >
              {m.worksScroll.viewAll}
            </a>
          </div>
        </div>
      </FocusIn>
    </div>

    <div
      data-works-stage
      class="works-scroll__stage relative z-10"
      style={`height: ${scrollVh}vh`}
    >
      <div
        class="works-scroll__pin sticky top-0 flex h-screen flex-col overflow-hidden"
      >
        <div
          class="works-scroll__viewport relative min-h-0 flex-1 overflow-hidden"
        >
          <div
            data-works-track
            class="works-scroll__track flex flex-col will-change-transform"
          >
            {
              works.map((work, i) => (
                <article
                  data-works-slide
                  data-index={i}
                  class={`group grid h-full min-h-0 shrink-0 grid-cols-1 items-center gap-12 md:grid-cols-12 ${i % 2 === 1 ? "md:*:data-works-media:order-2" : ""}`}
                >
                  <ScaleIn
                    data-works-media
                    enhance
                    once={false}
                    duration={900}
                    delay={0}
                    initialScale={0.94}
                    easing={cinematic}
                    margin={`0px 0px ${inViewMargin} 0px`}
                    class="overflow-hidden rounded-lg bg-background/10 md:col-span-7"
                  >
                    <figure data-cursor="grab">
                      {typeof work.image === "string" ? (
                        <img
                          src={work.image}
                          alt={work.title}
                          loading="lazy"
                          decoding="async"
                          class="aspect-video w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                        />
                      ) : (
                        <Image
                          src={work.image}
                          alt={work.title}
                          class="aspect-video w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                        />
                      )}
                    </figure>
                  </ScaleIn>
                  <div
                    class={`md:col-span-5 ${i % 2 === 1 ? "md:text-right" : ""}`}
                  >
                    <FadeInText
                      enhance
                      once={false}
                      as="p"
                      duration={0.85}
                      delay={0.05}
                      blur="0px"
                      yOffset={24}
                      easing={cinematic}
                      inViewMargin={inViewMargin}
                      class={`mb-1 max-w-sm font-display text-5xl leading-none italic text-background/25 md:text-6xl ${i % 2 === 1 ? "md:ml-auto" : ""}`}
                      aria-hidden="true"
                    >
                      {work.no}
                    </FadeInText>
                    <span class="sr-only">{m.worksScroll.workNo.replace("{no}", work.no)}</span>
                    <FadeInText
                      enhance
                      once={false}
                      duration={0.8}
                      delay={0.12}
                      blur="0px"
                      yOffset={20}
                      easing={cinematic}
                      inViewMargin={inViewMargin}
                      class={`mb-5 flex max-w-sm items-center justify-between gap-4 font-mono text-xs ${i % 2 === 1 ? "md:ml-auto" : ""}`}
                    >
                      <span class="text-background/90">{work.tag}</span>
                      <span class="text-xs uppercase tracking-[0.18em] text-background/45">
                        {work.year}
                      </span>
                    </FadeInText>
                    <FadeInText
                      enhance
                      once={false}
                      as="h3"
                      duration={0.85}
                      delay={0.18}
                      blur="0px"
                      yOffset={22}
                      easing={cinematic}
                      inViewMargin={inViewMargin}
                      class="mb-4 font-display text-3xl italic md:text-4xl"
                    >
                      {work.title}
                    </FadeInText>
                    <FadeInText
                      enhance
                      once={false}
                      duration={0.8}
                      delay={0.24}
                      blur="0px"
                      yOffset={18}
                      easing={cinematic}
                      inViewMargin={inViewMargin}
                      class="max-w-lg text-base leading-relaxed text-background/60"
                    >
                      {work.desc}
                    </FadeInText>
                    <FadeInText
                      enhance
                      once={false}
                      duration={0.75}
                      delay={0.32}
                      blur="0px"
                      yOffset={14}
                      easing={cinematic}
                      inViewMargin={inViewMargin}
                      class={`mt-8 ${i % 2 === 1 ? "md:flex md:justify-end" : ""}`}
                    >
                      <a
                        href={`/works/${work.slug}`}
                        data-cursor="focus"
                        data-cursor-label="View"
                        aria-label={m.worksScroll.viewWork.replace("{title}", work.title)}
                        class="group/cta inline-flex items-center gap-2 border-b border-background/40 pb-0.5 font-mono text-[10px] uppercase tracking-[0.2em] text-background transition-colors hover:border-background"
                      >
                        {m.worksScroll.detail}
                        <PreviewIcon
                          size={14}
                          class="transition-transform group-hover/cta:translate-x-0.5 group-hover/cta:-translate-y-0.5"
                        />
                      </a>
                    </FadeInText>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <div class="flex shrink-0 items-center gap-4 pb-8">
          <div class="h-px flex-1 bg-background/20">
            <div data-works-bar class="h-full w-0 origin-left bg-background">
            </div>
          </div>
          <p
            data-works-counter
            class="font-mono text-[10px] uppercase tracking-[0.2em] opacity-60"
          >
            01 / {String(works.length).padStart(2, "0")}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .works-scroll__grid span {
    background-color: color-mix(in oklch, var(--background) 11%, transparent);
  }

  .works-scroll__viewport {
    height: 100%;
    overflow: hidden;
  }

  .works-scroll__track {
    height: 100%;
    backface-visibility: hidden;
  }

  .works-scroll__track [data-works-slide] {
    height: 100%;
    min-height: 100%;
    overflow: hidden;
  }
</style>

<script>
  import { bindWorksScroll } from "@/service/works.service";

  bindWorksScroll();
  document.addEventListener("astro:page-load", () => bindWorksScroll());
</script>
