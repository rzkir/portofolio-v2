---
import Dialog from "@/components/ui/dialog.astro";
import FocusIn from "@/components/FocusIn.astro";
import { getCredentials } from "@/service/archivments.service";
import { getCareers } from "@/service/career.service";
import {
  getGroupedSkills,
  SKILL_CATEGORY_LABELS,
} from "@/service/skills.service";
import { getLocale, getMessages } from "@/lib/i18n";

const locale = getLocale(Astro);
const m = getMessages(locale);

const [skillGroups, credentials, careers] = await Promise.all([
  getGroupedSkills(),
  getCredentials(),
  getCareers(),
]);

const featuredCredentials = credentials.slice(0, 8);
const remainingCredentials = credentials.length - featuredCredentials.length;
---

<Dialog id="cv-dialog" class="max-w-5xl overflow-y-auto">
  <slot name="trigger" slot="trigger">
    <button
      type="button"
      data-dialog-open="cv-dialog"
      class="group inline-flex items-center gap-3 rounded-full bg-foreground px-6 py-3 text-sm font-medium text-background transition-transform hover:-translate-y-0.5"
    >
      {m.cv.trigger}
      <span class="transition-transform group-hover:translate-x-1">→</span>
    </button>
  </slot>

  <h2 id="cv-dialog-title" class="sr-only">
    {m.cv.title}
  </h2>
  <p id="cv-dialog-desc" class="sr-only">
    {m.cv.description}
  </p>

  <article
    class="px-8 py-10 sm:px-12 sm:py-14"
    aria-labelledby="cv-dialog-title"
    aria-describedby="cv-dialog-desc"
  >
    <FocusIn
      class="flex items-end justify-between border-b border-border pb-6"
      delay={0}
      duration={0.85}
    >
      <div>
        <p
          class="font-mono text-xs tracking-[0.3em] text-muted-foreground uppercase"
        >
          {m.cv.eyebrow}
        </p>
        <h2 class="mt-3 font-display text-4xl leading-none italic sm:text-5xl">
          Rizki Ramadhan
        </h2>
        <p class="mt-2 text-sm text-muted-foreground">
          {m.cv.role}
        </p>
      </div>
      <div
        class="hidden text-right font-mono text-xs tracking-widest uppercase sm:block"
      >
        {m.cv.updated}
        <br />
        <span class="text-accent">Jun 2026</span>
      </div>
    </FocusIn>

    <FocusIn
      as="section"
      class="mt-8 grid grid-cols-12 gap-6 border-b border-border pb-8"
      delay={60}
      duration={0.85}
    >
      <h3
        class="col-span-12 font-mono text-xs tracking-[0.3em] text-muted-foreground uppercase sm:col-span-3"
      >
        {m.cv.profile}
      </h3>
      <p
        class="col-span-12 text-sm leading-relaxed text-foreground/80 sm:col-span-9"
      >
        {m.cv.profileBody}
      </p>
    </FocusIn>

    <section class="mt-8 grid grid-cols-12 gap-6 border-b border-border pb-8">
      <FocusIn
        as="h3"
        class="col-span-12 font-mono text-xs tracking-[0.3em] text-accent uppercase sm:col-span-3"
        delay={100}
        duration={0.85}
      >
        {m.cv.experience}
      </FocusIn>
      <div class="col-span-12 space-y-6 sm:col-span-9">
        {
          careers.map((career, i) => (
            <FocusIn
              delay={140 + i * 55}
              duration={0.85}
              class="flex flex-col gap-1 border-l border-border pl-4"
            >
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <p class="text-base font-medium">{career.role}</p>
                <span class="font-mono text-xs tracking-widest text-accent uppercase">
                  {career.range}
                </span>
              </div>
              <p class="text-xs tracking-widest text-accent uppercase">
                {career.org}
              </p>
              <p class="mt-1 text-sm leading-relaxed whitespace-pre-line text-foreground/75">
                {career.desc}
              </p>
            </FocusIn>
          ))
        }
      </div>
    </section>

    <section class="mt-8 grid grid-cols-12 gap-6 border-b border-border pb-8">
      <FocusIn
        as="h3"
        class="col-span-12 font-mono text-xs tracking-[0.3em] text-accent uppercase sm:col-span-3"
        delay={120}
        duration={0.85}
      >
        {m.cv.skills}
      </FocusIn>
      <div class="col-span-12 space-y-5 sm:col-span-9">
        {
          SKILL_CATEGORY_LABELS.map((group, i) =>
            skillGroups[group.key].length > 0 ? (
              <FocusIn delay={160 + i * 50} duration={0.85}>
                <p class="mb-2 font-mono text-xs tracking-[0.2em] text-accent uppercase">
                  {group.label}
                </p>
                <div class="flex flex-wrap gap-2">
                  {skillGroups[group.key].map((s) => (
                    <span class="inline-flex items-center gap-2 rounded-full border border-border px-3 py-1 text-xs">
                      <img
                        src={s.imageUrl}
                        alt=""
                        width={16}
                        height={16}
                        loading="lazy"
                        decoding="async"
                        class="size-4 object-contain"
                      />
                      {s.title}
                    </span>
                  ))}
                </div>
              </FocusIn>
            ) : null,
          )
        }
      </div>
    </section>

    <section class="mt-8 grid grid-cols-12 gap-6 border-b border-border pb-8">
      <FocusIn
        as="h3"
        class="col-span-12 font-mono text-xs tracking-[0.3em] text-accent uppercase sm:col-span-3"
        delay={120}
        duration={0.85}
      >
        {m.cv.certifications}
      </FocusIn>
      <ul class="col-span-12 space-y-2 text-sm sm:col-span-9">
        {
          featuredCredentials.map((c: any, i: any) => (
            <FocusIn
              as="li"
              delay={160 + i * 35}
              duration={0.8}
              class="flex items-baseline justify-between gap-4 border-b border-border/60 pb-2"
            >
              <span class="leading-snug">{c.title}</span>
              <span class="shrink-0 font-mono text-xs tracking-widest text-accent uppercase">
                {c.issuer} · {c.year}
              </span>
            </FocusIn>
          ))
        }
        {
          remainingCredentials > 0 && (
            <FocusIn
              as="li"
              delay={160 + featuredCredentials.length * 35}
              duration={0.8}
              class="pt-1 font-mono text-xs tracking-widest text-accent uppercase"
            >
              {m.cv.moreCerts.replace("{count}", String(remainingCredentials))}
            </FocusIn>
          )
        }
      </ul>
    </section>

    <FocusIn
      as="section"
      class="mt-8 grid grid-cols-12 gap-6"
      delay={140}
      duration={0.85}
    >
      <h3
        class="col-span-12 font-mono text-xs tracking-[0.3em] text-accent uppercase sm:col-span-3"
      >
        {m.cv.contact}
      </h3>
      <dl class="col-span-12 grid grid-cols-2 gap-4 text-sm sm:col-span-9">
        <div>
          <dt class="text-xs tracking-widest text-accent uppercase">
            {m.cv.contactEmail}
          </dt>
          <dd class="mt-1">hello@rizkiramadhan.biz.id</dd>
        </div>
        <div>
          <dt class="text-xs tracking-widest text-accent uppercase">
            {m.cv.contactWebsite}
          </dt>
          <dd class="mt-1">rizkiramadhan.biz.id</dd>
        </div>
        <div>
          <dt class="text-xs tracking-widest text-accent uppercase">
            {m.cv.contactLocation}
          </dt>
          <dd class="mt-1">Bogor, ID (UTC+7)</dd>
        </div>
        <div>
          <dt class="text-xs tracking-widest text-accent uppercase">
            {m.cv.contactStatus}
          </dt>
          <dd class="mt-1 text-accent">{m.cv.statusValue}</dd>
        </div>
      </dl>
    </FocusIn>

    <FocusIn
      class="mt-10 flex flex-wrap items-center justify-between gap-4 border-t border-border pt-6"
      delay={200}
      duration={0.85}
    >
      <p class="font-mono text-xs tracking-widest uppercase">
        {m.cv.pdfNote}
      </p>
      <a
        href="/cv-rizkiramadhan.pdf"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full bg-foreground px-5 py-2 text-xs font-medium text-background transition-transform hover:-translate-y-0.5"
      >
        {m.cv.download} →
      </a>
    </FocusIn>
  </article>
</Dialog>

<script>
  import { bindCvDialogAnimations } from "@/lib/cv-dialog-animations";

  bindCvDialogAnimations();
  document.addEventListener("astro:page-load", () => bindCvDialogAnimations());
</script>
