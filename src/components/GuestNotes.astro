---
import FocusIn from "@/components/FocusIn.astro";
---

<section id="catatan" class="mx-auto max-w-6xl px-6 py-32">
  <FocusIn class="mb-12 flex items-end justify-between">
    <div>
      <p class="mb-4 font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase">Buku Tamu / 11</p>
      <h2 class="font-display text-5xl italic">Tinggalkan catatan.</h2>
    </div>
    <span id="guest-notes-count" class="hidden font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase md:block">
      0 catatan
    </span>
  </FocusIn>

  <div class="grid gap-12 lg:grid-cols-12">
    <form id="guest-notes-form" class="self-start border border-border bg-surface/40 p-8 lg:col-span-5">
      <p class="mb-6 font-mono text-[10px] tracking-[0.2em] text-accent uppercase">// LEAVE_A_NOTE</p>
      <div class="space-y-5">
        <label class="block">
          <span class="mb-2 block font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase">Nama</span>
          <input
            id="guest-name"
            type="text"
            name="name"
            maxlength="60"
            required
            placeholder="Siapa kamu?"
            class="w-full border-b border-border bg-transparent py-2 outline-none transition-colors focus:border-accent"
          />
        </label>
        <label class="block">
          <span class="mb-2 flex items-center justify-between font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase">
            <span>Catatan</span>
            <span id="guest-message-count">0/280</span>
          </span>
          <textarea
            id="guest-message"
            name="message"
            maxlength="280"
            required
            rows={4}
            placeholder="Tulis apa pun — sapa, kritik, atau pesan singkat."
            class="w-full resize-none border-b border-border bg-transparent py-2 outline-none transition-colors focus:border-accent"
          ></textarea>
        </label>
        <p id="guest-notes-error" class="hidden font-mono text-xs text-destructive"></p>
        <button
          type="submit"
          data-cursor="focus"
          data-cursor-label="Send"
          class="inline-flex items-center gap-3 rounded-full bg-foreground px-6 py-3 text-sm font-medium text-background transition-colors hover:bg-accent disabled:opacity-50"
        >
          Kirim catatan →
        </button>
      </div>
    </form>

    <div class="lg:col-span-7">
      <div
        id="guest-notes-empty"
        class="grid h-64 place-items-center border border-dashed border-border text-sm text-muted-foreground"
      >
        Belum ada catatan — jadilah yang pertama.
      </div>
      <ul id="guest-notes-list" class="hidden grid gap-4 sm:grid-cols-2"></ul>
    </div>
  </div>
</section>

<script>
  import { initGuestNotes } from "@/lib/guest-notes";

  initGuestNotes();
  document.addEventListener("astro:page-load", initGuestNotes);
</script>
