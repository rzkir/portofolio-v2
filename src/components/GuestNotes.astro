---
import FocusIn from "@/components/FocusIn.astro";
import Input from "@/components/ui/input.astro";
import Select from "@/components/ui/select.astro";
import Textarea from "@/components/ui/textarea.astro";
import { getGuestNotes, getProviderLabel, MESSAGE_PROVIDERS } from "@/service/noted.service";

const notes = await getGuestNotes();

const providerOptions = MESSAGE_PROVIDERS.map(({ value, label }) => ({
  value,
  label,
  selected: value === "website",
}));
---

<section id="catatan" class="mx-auto max-w-6xl px-6 py-32">
  <FocusIn class="mb-12 flex items-end justify-between">
    <div>
      <p class="mb-4 font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase">Buku Tamu / 11</p>
      <h2 class="font-display text-5xl italic">Tinggalkan catatan.</h2>
    </div>
    <span id="guest-notes-count" class="hidden font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase md:block">
      {notes.length} catatan
    </span>
  </FocusIn>

  <div class="grid gap-12 lg:grid-cols-12">
    <form id="guest-notes-form" class="self-start border border-border bg-surface/40 p-8 lg:col-span-5">
      <p class="mb-6 font-mono text-[10px] tracking-[0.2em] text-accent uppercase">// LEAVE_A_NOTE</p>
      <div class="space-y-5">
        <Input
          label="Nama"
          id="guest-name"
          name="name"
          maxlength={60}
          placeholder="Siapa kamu?"
          required
        />
        <Select
          label="Dari mana"
          id="guest-provider"
          name="provider"
          options={providerOptions}
          required
        />
        <Textarea
          label="Catatan"
          id="guest-message"
          name="message"
          maxlength={280}
          required
          rows={4}
          placeholder="Tulis apa pun — sapa, kritik, atau pesan singkat."
        >
          <span slot="label-extra" id="guest-message-count">0/280</span>
        </Textarea>
        <p id="guest-notes-error" class="hidden font-mono text-xs text-destructive"></p>
        <button
          type="submit"
          data-cursor="focus"
          data-cursor-label="Send"
          class="inline-flex items-center gap-3 rounded-full bg-foreground px-6 py-3 text-sm font-medium text-background transition-colors hover:bg-accent disabled:opacity-50"
        >
          Kirim catatan →
        </button>
      </div>
    </form>

    <div class="lg:col-span-7">
      <div
        id="guest-notes-empty"
        class:list={["grid h-64 place-items-center border border-dashed border-border text-sm text-muted-foreground", { hidden: notes.length > 0 }]}
      >
        Belum ada catatan — jadilah yang pertama.
      </div>
      <ul id="guest-notes-list" class:list={["grid gap-4 sm:grid-cols-2", { hidden: notes.length === 0 }]}>
        {
          notes.map((note) => (
            <li
              data-cursor="focus"
              data-cursor-label="Read"
              class="border border-border bg-background p-5 transition-colors hover:border-accent/40"
            >
              <p class="mb-3 font-display text-lg leading-snug italic">"{note.message}"</p>
              <div class="flex items-end justify-between border-t border-border pt-3">
                <div>
                  <p class="text-sm font-medium">— {note.name}</p>
                  <p class="mt-1 font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase">
                    {getProviderLabel(note.provider)}
                  </p>
                </div>
                <p class="font-mono text-[10px] tracking-[0.2em] text-muted-foreground uppercase">
                  {
                    new Date(note.createdAt).toLocaleDateString("id-ID", {
                      day: "2-digit",
                      month: "short",
                    })
                  }
                </p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<script define:vars={{ initialNotes: notes }}>
  import { initGuestNotes } from "@/lib/guest-notes";

  initGuestNotes({ initialNotes });
  document.addEventListener("astro:page-load", () => initGuestNotes({ initialNotes }));
</script>
