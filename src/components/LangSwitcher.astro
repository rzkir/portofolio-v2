---
import { cn } from "@/lib/utiles";
import { getLocale, getMessages, langHref, type Locale } from "@/lib/i18n";

const locale = getLocale(Astro);
const m = getMessages(locale);
const { pathname, search } = Astro.url;

const pillClass = cn(
  "inline-flex items-center gap-0.5 rounded-full border border-border bg-surface/55 p-0.5",
  "group-[.is-inverse]/site-header:border-background/18 group-[.is-inverse]/site-header:bg-background/8",
);

const linkClass = (lang: Locale) =>
  cn(
    "rounded-full px-2 py-1 font-mono text-[0.5rem] tracking-[0.16em] uppercase no-underline transition-colors",
    locale === lang
      ? "bg-foreground/8 text-accent"
      : "text-muted-foreground hover:text-foreground",
    "group-[.is-inverse]/site-header:text-background/65 group-[.is-inverse]/site-header:hover:text-background",
    locale === lang &&
      "group-[.is-inverse]/site-header:bg-background/12 group-[.is-inverse]/site-header:text-background",
  );
---

<div
  class={cn(pillClass, "site-header__lang")}
  role="group"
  aria-label={m.lang.label}
>
  <a
    href={langHref(pathname, search, "id")}
    class={linkClass("id")}
    aria-current={locale === "id" ? "true" : undefined}
  >
    {m.lang.id}
  </a>
  <a
    href={langHref(pathname, search, "en")}
    class={linkClass("en")}
    aria-current={locale === "en" ? "true" : undefined}
  >
    {m.lang.en}
  </a>
</div>
